@page "/ListOfDrafts"


@using ApplicationLayer.Entities.Drafts

@inject IHttpClientFactory _clientFactory
@inject Microsoft.Extensions.Configuration.IConfiguration _config

<div class="row" align="center">
    <div align="center">
        <h3>Available Checks</h3>
    </div>
</div>
<br />
<div>
    <GenDatabaseList Elements="getList">

        <TableHeader>
            <th>Check Number</th>
            <th>Certified Date</th>
            <th>Certified No</th>
            @*  <th>Chain of Title</th>
            <th>Book</th>
            <th>Page</th> *@
            @* <th>Volume</th> *@
        </TableHeader>

        <RowTemplate Context="entityModel">
            <td><a href="@($"/drafts/{Convert.ToString(entityModel.Id)}/{entityModel.DraftNo}")" class="nav-link">@entityModel.DraftNo</a></td>
            <td>@entityModel.PropertyType</td>
            <td>@entityModel.DraftFormId</td>
            @* <td>@contracts.CertifiedMailNo</td>
            <td>@contracts.MainCompany</td>
            <td>@contracts.Responsible</td> *@
            @* <td>@contracts.Volume</td> *@
        </RowTemplate>
        <HrefEditModal>
            <a href="@($"#edit{title}")" class="edit" data-toogle="modal">
                <i class="material-icons" data-toogle="tooltip" title="Edit">&#xE254;</i>
            </a>
        </HrefEditModal>
        <HrefDeleteModal>
            <a href="@($"#delete{title}")" class="delete" data-toogle="modal">
                <i class="material-icons" data-toogle="tooltip" title="Delete">&#xE872;</i>
            </a>
        </HrefDeleteModal>
    </GenDatabaseList>
</div>



@code {

    // Districts
    // Regions
    // Survey
    // TwnRngSec

    static string title = "CreateOrUpdateTractMainForm";

    string errorString;

    protected override async Task OnInitializedAsync()
    {
        //await PopulateTracts();

        //// ADDED TO IMPLEMENT LOADING INDICATOR
        await Task.Run(() => PopulateList());
    }

    #region RETRIEVE LIST

    List<DraftMasterMain> getList { get; set; } = new List<DraftMasterMain>();

    async Task<List<DraftMasterMain>> PopulateList(int page = 1, int quantityPerPage = 10)
    {
        var request = new HttpRequestMessage(HttpMethod.Get,
        _config["API_URL"] + "DraftMasterMain");
        var client = _clientFactory.CreateClient();
        var response = await client.SendAsync(request);

        if (response.IsSuccessStatusCode)
        {
            // PART OF THE LOADING INDICATOR
            System.Threading.Thread.Sleep(0);

            //totalPageQuantity = int.Parse(response.Headers.GetValues("pagesQuantity").FirstOrDefault());

            using var responseStream = await response.Content.ReadAsStreamAsync();
            getList = await JsonSerializer.DeserializeAsync<List<DraftMasterMain>>(responseStream);

            errorString = null;

        }
        else
        {
            errorString = $"There was an error getting Tracts: {response.ReasonPhrase}";
        }

        return getList;
    }

    #endregion RETRIEVE LIST OF TRACTS
}

