@page "/AddUpdateBurdenInfo"

@inject IBurdenServices _burdenServices;

@using ApplicationLayer.Entities.Burden
@using ApplicationLayer.Services.RelatedProperties.Burdens

@inherits LeaseMainBase

@{
    /* public */
    Burdens tractBurdens = new Burdens();
    var showClass = IsVisible ? "d-block" : "d-none";

}


<TabControl>
    <TabPage Text="Documents">
        <RelatedNotes EntityID=""></RelatedNotes>
    </TabPage>
</TabControl>

<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width, initial-sclae=1">
<link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Roboto|Varela+Round" />
<link rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Icons" />
<link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css" />
<link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css" />
<link href="~/css/style.css" rel="stylesheet" />

<div class="modal p-3 @showClass" data-bs-autohide="true" data-bs-delay="5000" style="align-self:center; ">
    <div class="container position-relative"
    style="overflow:scroll;
                        justify-content:left;
                        border-width:medium;
                        width:-webkit-fit-content;
                        height:450px;">

        <div class="modal-body" style="align-self:center">
            <div class="modal-content align-content-center">
                <div class="modal-header">
                    <button type="button" class="btn-close" aria-label="Close" @onclick="Close"></button>
                </div>
                <div class="card" style="align-content:center; width:-webkit-fit-content; height:max-content">
                    <div class="card-header">
                        @{
                            if (EntityId != null)
                            {
                                // <strong class="me-auto">New Working Interest Form for Lease : @($"  {LeaseID}")</strong>
                            }
                            else
                            if (LeaseID != null)
                            {
                                <strong class="me-auto">New Working Interest Form for Lease : @($"  {LeaseID}")</strong>
                            }
                            else
                                        if (EasementId != null)
                            {
                                <strong class="me-auto">New Working Interest Form for Easement @($"  {EasementId}")</strong>
                            }
                            else
                                        if (SuaId != null)
                            {
                                <strong class="me-auto">New Working Interest Form for SUA @($"  {SuaId}")</strong>
                            }
                            else
                                        if (RowId != null)
                            {
                                <strong class="me-auto">New Working Interest Form for ROW @($"  {RowId}")</strong>
                            }
                            else
                                        if (TractID != null)
                            {
                                <strong class="me-auto">New Working Interest Form for Tract @($"  {TractID}")</strong>
                            }
                            else
                            {
                                <strong class="me-auto">New Working Interest Form</strong>
                            }
                        }
                    </div>
                    <div class="card-body m-auto" style="width:auto">
                        <form method="post" class="mt-3" enctype="multipart/form-data">
                            <div class="form-row">
                                <br />
                                <button type="submit" class="btn btn-primary" style="width:150px;" @onclick="(() => SaveButton(tractBurdens))"> Save </button>
                                @* <button type="submit" class="btn btn-primary" style="width:150px;" @onclick="Save"> Save </button> *@
                                <button type="submit" class="btn btn-danger" style="width:150px;" @*onclick="OnPostCreateTract" *@>Delete</button>
                                <button type="button" class="btn btn-primary" style="width:150px;" @*onclick="OnPostCreateTract" *@>Print</button>
                                <div class="col-xl-12 col-lg-6">
                                    <br />
                                    <div class="card accent-card mb-3">
                                        <div class="card-header">Identification</div>
                                        <div class="card-body">
                                            <div class="col-12 col-lg-6">
                                                <label>Owner ID</label>
                                                <InputSelect @bind-Value="tractBurdens.OwnerId" class="form-control" placeholder="Select a Owner"></InputSelect>
                                                <br />
                                                <label>Interest Formula</label>
                                                <InputText @bind-Value="tractBurdens.InterestFormula" class="form-control" placeholder="1/16 or .0025"></InputText>
                                            </div>
                                            <div class="col-12 col-lg-6">
                                                <label>Interest</label>
                                                <InputNumber @bind-Value="tractBurdens.BurdenInterest" class="form-control" placeholder="0.00000000"></InputNumber>
                                                <br />
                                                <label>Type</label>
                                                <InputText @bind-Value="tractBurdens.BurdenType" class="form-control" placeholder="Burden Type"></InputText>
                                                <br />
                                                <label>Amount</label>
                                                <InputNumber @bind-Value="tractBurdens.BurdenAmount" class="form-control" placeholder="0.00"></InputNumber>
                                            </div>
                                            <div class="form-row">
                                                <div class="col-2 ">
                                                    <InputText @bind-Value="EntityId" class="form-control" placeholder="Entity"></InputText>
                                                </div>
                                                <div class="col-2 ">
                                                    <InputText @bind-Value="TractID" class="form-control" placeholder="TractID"></InputText>
                                                </div>
                                                <div class="col-2 ">
                                                    <InputText @bind-Value="LeaseID" class="form-control" placeholder="LeaseId"></InputText>
                                                </div>
                                                <div class="col-2 ">
                                                    <InputText @bind-Value="EasementId" class="form-control" placeholder="EasementId"></InputText>
                                                </div>
                                                <div class="col-2 ">
                                                    <InputText @bind-Value="SuaId" class="form-control" placeholder="SuaId"></InputText>
                                                </div>
                                                <div class="col-2 ">
                                                    <InputText @bind-Value="RowId" class="form-control" placeholder="RowId"></InputText>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>


