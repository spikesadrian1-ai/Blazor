                                    <option value="10">Tenant-in-Common</option>
                                    <option value="11">Unknown</option>
                                    <option value="12">Usufruct</option>
                                </select> *@
                                    <select id="wellAcquisitionTypes" class="custom-select">
                                        <option value="0">Select Tenure Code</option>
                                        @foreach (var item in tenureCodes)
                                        {
                                            <option value="@item.">@item.</option>
                                            //<option value="@item.TenureCode">@item.TenureCode</option>
                                        }
                                    </select>

                                }

                                @if (!string.IsNullOrWhiteSpace(EntityID))
                                {
                                    <InputSelect @bind-Value="owners.TenureCode" class="form-control-sm text-sm-right" style="align-self:center; width:300px;" placeholder="(Ex. EIN NUMBER)"></InputSelect>
                                }
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="col-3">
                                <label class="opacity-50 form-control-sm mb-0" asp-for="TotalAcreage">No Pay</label>
                            </div>
                            <div class="col" style="padding-bottom:3px;">
                                @* <InputSelect @bind-Value="owners.NoPayCode" class="form-control-sm text-sm-right" style="align-self:center; width:300px;" placeholder="(Ex. 123-45-6789)"></InputSelect> *@
                                <select id="ProductSelectionDropdown" class="form-control ">
                                    <option value="0">Choose No-Pay Code</option>
                                    <option value="1">Not Applicable</option>
                                    <option value="2">No-Pay - Mining Royalty Checks</option>
                                </select>
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="col-3">
                                <label class="opacity-50 form-control-sm mb-0" asp-for="TotalAcreage">Class</label>
                            </div>
                            <div class="col">
                                @* <InputSelect @bind-Value="owners.GeneralClass" class="form-control-sm text-sm-right" style="align-self:center; width:300px;" placeholder=""></InputSelect> *@
                                <select id="ProductSelectionDropdown" class="form-control">
                                    <option value="0">Choose General Class</option>
                                    <option value="1">Attorney</option>
