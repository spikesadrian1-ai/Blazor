                                    <option value="10">Mortgage Holder</option>
                                    <option value="11">Non-Participating Royalty Owner</option>
                                    <option value="12">Operator</option>
                                    <option value="13">ORRI Owner</option>
                                    <option value="14">Prospect Originator</option>
                                    <option value="15">Purchaser/Gatherer</option>
                                    <option value="16">Signatory Authority</option>
                                    <option value="17">Surface Tenant</option>
                                    <option value="18">Surface Owner</option>
                                    <option value="19">Unleased Mineral Owner</option>
                                    <option value="20">Water Rights Owner</option>
                                    <option value="21">Working Interest Participant</option>

                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="card-header form-control">Banking Information</div>
                    <div class="card-body">
                        <div class="form-row">
                            <div class="col-3 ">
                                <label class="opacity-50 form-control-sm mb-0" asp-for="TotalAcreage">Default</label>
                            </div>
                            <div class="col" style="padding-bottom:3px;">
                                <InputText @bind-Value="owners.DefaultBankId" class="form-control text-sm-right" style="align-self:center; width:350px;" placeholder="(Ex. EIN NUMBER)"></InputText>
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="col-3">
                                <label class="opacity-50 form-control-sm mb-0" asp-for="TotalAcreage">Bank No</label>
                            </div>
                            <div class="col" style="padding-bottom:3px;">
                                <InputText @bind-Value="owners.BankAccountNo" class="form-control text-sm-right" style="align-self:center; width:350px;" placeholder="(Ex. 123-45-6789)"></InputText>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</EditForm>


