@page "/OwnerInfo"

@using BlazorWebApp.Components.Pages.OG_Forms.Bus._Assoc
@using ApplicationLayer.Entities.Owners;
@using ApplicationLayer.Services.DropdownLists;


@inherits OwnerMainBase

@{

}


<div class="form-row" style="">
    <button type="submit" class="btn btn-primary" style="width:150px;" @onclick="() => SaveNewOwnerAsync(ownersD)"> Save </button>
    <button type="submit" class="btn btn-danger" style="width:150px;" @onclick="() => DeleteOwner(ownersD)">Delete</button>
    <button type="button" class="btn btn-primary" style="width:150px;" @*onclick="OnPostCreateTract" *@>Print</button>
    <NavLink id="" name="ViewTractListBttn" class="btn btn-primary" style="width:150px;" href="@($"/ListOfOwnersAndAssociates")"> View Owners/Associates</NavLink>
</div>
<EditForm Model="@owners">
    <div class="container border border-top border-bottom m-1 auto">
        @* border-dark *@
        <div class="card accent-card">
            <div class="card-body">
                <div class="card-header form-control-sm">
                    @{
                        if (InitialState == false)
                        {
                            <strong class="me-auto">Information for Owner: @IdFromListView.ToString()</strong>
                        }
                        else
                        if (InitialState == true)
                        {
                            <strong class="me-auto">New Owner / Business Associates Form</strong>
                        }
                    }
                </div>
            </div>
            <div class="form-row">
                <div class="col" style="align-items:center; align-content:center;">
                    @* <div class="card-body"> *@
                    <div class="card-header form-control">Owner Information</div>
                    @* </div> *@
                    <div class="card-body">
                        <div class="form-row">
                            <div class="col-2 ">
                                <label class="opacity-50 form-control-sm mb-0">Owner </label>
                            </div>
                            <div class="col" style="padding-bottom:3px;">
                                @* owners.OwnerId*@   @* OnOwnerIdEntered="OwnerIdEntered" *@
                                @* <InputText @bind-Value="owners.OwnerId"
                                           class="form-control text-sm-right" style="align-self:center; width:350px;" placeholder="(Ex. JM001)"></InputText> *@
                                @* @ResponseStatus.ToString() *@
                                @* <DataAnnotationsValidator></DataAnnotationsValidator>
                                <ValidationSummary></ValidationSummary> *@
                                @* @ResponseStatus *@
                                @if (!string.IsNullOrEmpty(owners.OwnerId))
                                {
                                    DoesIdAlreadyExists(owners, responseStatus);
                                    //VerifyOwnerIdIsUniqueObj(owners.OwnerId);
                                    //RequestResponseStatus = Response;
                                    //Response = RequestResponseStatus;
                                }
                                @if (InitialState == false)
                                {
                                    /// COMMENT: USER HAS CHOSEN A TRACT FROM LIST COMPONENT
                                    var testName2 = "";

                                    if (owners.OwnerId == null)
                                    {
                                        testName2 = IdFromListView;
                                        //owners.OwnerId = IdFromListView;
                                    }
                                    else
                                    {
                                        testName2 = owners.OwnerId.ToString();
                                        owners.OwnerId = IdFromListView;
                                        getOwner.OwnerId = IdFromListView;

                                    }

                                    /// COMMENT: WHEN USER HAS ALREADY SELECTED A TRACT THEN VIEWED A LEASE AND HAS NOW CHOSEN TO VIEW A DIFFERENT TRACT
                                    /// PURPOSE: TO ENSURE LEASE MODEL HAS BEEN CLEARED AND REHYDRATED WITH THE "NEW" ONE
                                    /// PROBLEM SOLVED: LOSS/MISSING DATA

                                    var testName3 = getOwner.OwnerId.ToString();

                                    /// COMMENT: CHECK VARIABLES AND IF DIFF THEN USE NEW VARIABLE INSTEAD
                                    if (testName2 != testName3)
                                    {
                                        getOwner.OwnerId = getOwner.OwnerId.ToString();
                                        owners.OwnerId = IdFromListView; //getOwner.OwnerId.ToString();
                                        //PopulateFormBasedOnEntityID(getTracts);
                                    }
                                    else    //USER SELECTED LISTOFTRACTS COMPONENT TO SELECT A DIFFERENT TRACT - SHUD CHECK IF TRACTID INSTEAD OF AND OR ADDED TO
                                    if (OwnerID == owners.OwnerId)
                                    {
                                        OwnerID = getOwner.OwnerId.ToString();
                                        owners.OwnerId = IdFromListView; //getOwner.OwnerId.ToString();

                                    }

                                    <InputText @bind-Value="owners.OwnerId"
                                               class="form-control text-sm-right" style="align-self:center; width:350px;" placeholder="(Ex. JM001)"></InputText>
                                    @* @ResponseStatus.ToString() *@
                                    <DataAnnotationsValidator></DataAnnotationsValidator>
                                    <ValidationSummary></ValidationSummary>
                                    @* @ResponseStatus *@
                                }
                                else
                                if (InitialState == true)
                                {
                                    <input type="text" data-bind="@owners.OwnerId" class="form-control" value="@owners.OwnerId" style="align-self:center; width:275px;" placeholder="Enter Tract ID" />
                                }
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="col-2">
                                <label class="opacity-50 form-control-sm mb-0">Name</label>
                            </div>
                            <div class="col" style="padding-bottom:3px;">
                                <InputText @bind-Value="owners.FullName" class="form-control text-sm-right" style="align-self:center; width:350px;" placeholder="(Ex. James Smith)"></InputText>
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="col-2">
                            </div>
                            <div class="col" style="padding-bottom:3px;">
                                <InputSelect @bind-Value="owners.FileAs" class="form-control text-sm-right" style="align-self:center; width:350px;" placeholder=""></InputSelect>
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="col-2">
                                <label class="opacity-50 form-control-sm mb-0">Email</label>
                            </div>
                            <div class="col">
                                <InputText @bind-Value="owners.Email" class="form-control text-sm-right" style="align-self:center; width:350px;" placeholder="(Ex. jamessmith@gmail.com)"></InputText>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col">
                    @* <div class="card-body"> *@
                    <div class="card-header form-control">Tax Information</div>
                    @* </div> *@
                    <div class="card-body">
                        <div class="form-row">
                            <div class="col-2">
                                <label class="opacity-50 form-control-sm mb-0">Tax ID</label>
                            </div>
                            <div class="col" style="padding-bottom:3px;">
                                <InputText @bind-Value="owners.TaxId" class="form-control text-sm-right" style="align-self:center; width:350px;" placeholder="(Ex. EIN NUMBER)"></InputText>
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="col-2">
                                <label class="opacity-50 form-control-sm mb-0">SSN</label>
                            </div>
                            <div class="col" style="padding-bottom:3px;">
                                <InputText @bind-Value="owners.SpouseSsn" class="form-control text-sm-right" style="align-self:center; width:350px;" placeholder="(Ex. 123-45-6789)"></InputText>
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="col-2">
                                <label class="opacity-50 form-control-sm mb-0">Tax Type</label>
                            </div>
                            <div class="col">
                                @* <InputSelect @bind-Value="owners.TaxIdType" class="form-control-sm text-sm-right" style="align-self:center; width:300px;" placeholder=""></InputSelect> *@
                                <select id="ProductSelectionDropdown" class="form-control text-sm-right" style="align-self:center; width:350px;">
                                    <option value="0">Choose General Class</option>
                                    <option value="1">Company </option>
                                    <option value="2">Estate</option>
                                    <option value="3">Individual</option>
                                    <option value="4">Trust</option>
                                    <option value="5">Corporation</option>
                                    <option value="6">Non-Resident Alien</option>
                                    <option value="7">Resident Alien</option>
                                    <option value="8">Lessee</option>
                                    <option value="9">Government</option>
                                    <option value="10">Partnership</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="form-row">
                <div class="col" style="align-items:center; align-content:center;">
                    <div class="card-header form-control">Address Information</div>
                    <div class="card-body">
                        <div class="form-row">
                            <div class="col-2 ">
                                <label class="opacity-50 form-control-sm mb-0">Type</label>
                            </div>
                            <div class="col" style="padding-bottom:3px;">
                                @* <InputSelect @bind-Value="owners.AddressType" class="form-control-sm text-sm-right" style="align-self:center; width:175px;" placeholder=""></InputSelect> *@
                                <select id="ProductSelectionDropdown" class="form-control" style="width:350px;">
                                    <option value="0">Choose Address Types</option>
                                    <option value="1">General Mailing Address</option>
                                    <option value="2">Payment Obligation Check</option>
                                    <option value="3">Payment Obligation Ltr(s)</option>
                                    <option value="4">Revenue Distribution Check(s)</option>
                                    <option value="5">J.I.B.'s Mailing Address</option>
                                </select>
                            </div>
                            <div class="col" style="padding-bottom:3px;">
                                <button type="submit" class="btn" @onclick="() => AddNewAddress()" style="width:150px;" > + New Address </button>@* *@
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="col-2">
                                <label class="opacity-50 form-control-sm mb-0">Address</label>
                            </div>
                            <div class="col" style="padding-bottom:3px;">
                                <InputTextArea @bind-Value="owners.Address" class="form-control text-sm-right" style="align-self:center; width:300px; height:75px" placeholder=""></InputTextArea>
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="col">
                                <div class="form-row">
                                    <div class="col-4">
                                        <label class="opacity-50 form-control-sm mb-0">Business</label>
                                    </div>
                                    <div class="col" style="padding-bottom:3px;">
                                        <InputText @bind-Value="owners.Business" class="form-control text-sm-right" style="align-self:center; width:160px; padding-bottom:3px;" placeholder="(Ex. 1+(000)000-0000)"></InputText>
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="col-4">
                                        <label class="opacity-50 form-control-sm mb-0">Cell</label>
                                    </div>
                                    <div class="col" style="padding-bottom:3px;">
                                        <InputText @bind-Value="owners.Business2" class="form-control text-sm-right" style="align-self:center; width:160px; padding-bottom:3px;" placeholder="(Ex. 1+(000)000-0000)"></InputText>
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="col-4">
                                        <label class="opacity-50 form-control-sm mb-0">Home</label>
                                    </div>
                                    <div class="col">
                                        <InputText @bind-Value="owners.Home" class="form-control text-sm-right" style="align-self:center; width:160px;" placeholder="(Ex. 1+(000)000-0000)"></InputText>
                                    </div>
                                </div>
                            </div>
                            <div class="col">
                                <div class="form-row">
                                    <div class="col-3">
                                        <label class="opacity-50 form-control-sm mb-0">Fax</label>
                                    </div>
                                    <div class="col" style="padding-bottom:3px;">
                                        <InputText @bind-Value="owners.Fax" class="form-control text-sm-right" style="align-self:center; width:160px; padding-bottom:3px;" placeholder="(Ex. 1+(000)000-0000)"></InputText>
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="col-3">
                                        <label class="opacity-50 form-control-sm mb-0">Mobile</label>
                                    </div>
                                    <div class="col" style="padding-bottom:3px;">
                                        <InputText @bind-Value="owners.Mobile" class="form-control text-sm-right" style="align-self:center; width:160px;" placeholder="(Ex. 1+(000)000-0000)"></InputText>
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="col-3">
                                        <label class="opacity-50 form-control-sm mb-0">Web</label>
                                    </div>
                                    <div class="col">
                                        <InputText @bind-Value="owners.WebPage" class="form-control text-sm-right" style="align-self:center; width:160px;" placeholder="(Ex. www.abc123.com)"></InputText>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col">
                    <div class="card-header form-control">Owner Payment Information</div>
                    <div class="card-body">
                        <div class="form-row">
                            <div class="col-3 ">
                                <label class="opacity-50 form-control-sm mb-0" asp-for="TotalAcreage">Tenure</label>
