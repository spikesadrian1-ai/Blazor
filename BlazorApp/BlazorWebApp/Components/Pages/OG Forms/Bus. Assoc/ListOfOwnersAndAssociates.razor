@page "/ListOfOwnersAndAssociates"

@using ApplicationLayer.Entities.Owners

@inject IHttpClientFactory _clientFactory
@inject Microsoft.Extensions.Configuration.IConfiguration _config

<br />
<div class="row" align="center">
    <div align="center">
        <h3>Available ListOfOwnersAndAssociates</h3>
    </div>
</div>
<br />
<br />
<div>
    <GenDatabaseList Elements="getTracts">

        <TableHeader>
            <th>Owner ID</th>
            <th>Filed As</th>
            <th>Contact Name</th>
            <th>Full Name</th>
            <th>Tenure</th>
        </TableHeader>

        <RowTemplate Context="Tracts">
            <td><a href="@($"/Owner/{Tracts.Id}/{Tracts.OwnerId}")" class="nav-link">@Tracts.OwnerId</a></td>
            <td>@Tracts.FileAs</td>
            <td>@Tracts.ContactName</td>
            <td>@Tracts.FullName</td>
            <td>@Tracts.TenureCode</td>
        </RowTemplate>
        <HrefEditModal>
            <a href="@($"#edit{title}")" class="edit" data-toogle="modal">
                <i class="material-icons" data-toogle="tooltip" title="Edit">&#xE254;</i>
            </a>
        </HrefEditModal>
        <HrefDeleteModal>
            <a href="@($"#delete{title}")" class="delete" data-toogle="modal">
                <i class="material-icons" data-toogle="tooltip" title="Delete">&#xE872;</i>
            </a>
        </HrefDeleteModal>
    </GenDatabaseList>
</div>



@code {

    public ApplicationLayer.Entities.Owners.OwnerAddressesMain Tracts { get; set; } 
        = new ApplicationLayer.Entities.Owners.OwnerAddressesMain();
    // public DomainLayer.Entities.Bus._Assoc.Owners Tracts1 { get; set; } = new DomainLayer.Entities.Bus._Assoc.Owners(
    
    // );

    static string title = "CreateOrUpdateTractMainForm";

    string errorString;

    protected override async Task OnInitializedAsync()
    {
        //await PopulateTracts();

        //// ADDED TO IMPLEMENT LOADING INDICATOR
        await Task.Run(() => PopulateTracts());
    }

    #region RETRIEVE LIST OF TRACTS

    List<OwnerAddressesMain> getTracts { get; set; } = new List<OwnerAddressesMain>();

    async Task<List<OwnerAddressesMain>> PopulateTracts(int page = 1, int quantityPerPage = 10)
    {
        var request = new HttpRequestMessage(HttpMethod.Get,
        _config["API_URL"] + "OwnerAddressesMain");
        var client = _clientFactory.CreateClient();
        HttpResponseMessage response = await client.SendAsync(request);

        if (response.IsSuccessStatusCode)
        {
            // PART OF THE LOADING INDICATOR
            System.Threading.Thread.Sleep(0);

            //totalPageQuantity = int.Parse(response.Headers.GetValues("pagesQuantity").FirstOrDefault());

            using var responseStream = await response.Content.ReadAsStreamAsync();
            getTracts = await JsonSerializer.DeserializeAsync<List<OwnerAddressesMain>>(responseStream);

            errorString = null;

        }
        else
        {
            errorString = $"There was an error getting Tracts: {response.ReasonPhrase}";
        }

        return getTracts;
    }

    #endregion RETRIEVE LIST OF TRACTS
}
