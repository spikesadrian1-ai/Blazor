<EditForm Model="@CountySearch">
    <div class="container">    
        <InputText id="searchCountyTextbox" @bind-Value="CountySearch.CountyName" class="form-control" placeholder="Search"></InputText>
        @* {SCENARIO #1: NULL CHECKS INITIAL STATE OF THE APPLICATION} *@
        @if ((CountySearch.CountyName is null) &&
        (CountyDropdown.CountyName != string.Empty) && (CountyDropdown.CountyName is null) &&
        (CountyDropdown.StateId is null))        
        {
            //throw NullReferenceException => 
            //throw Exception("");
            //throw ArgumentNullException;
        }

        @* {SCENARIO #2: COUNTY SEARCH INITIALLY USED FIRST WITH COUNTYDROPDOWN AND STATE ID HAVING AN EMPTY STRING} *@
        @if ((CountySearch.CountyName != null) &&
        (CountyDropdown.CountyName != string.Empty) &&
        (CountyDropdown.CountyName != string.Empty) && (CountyDropdown.CountyName is null) &&
        (CountyDropdown.StateId is null))
        {
            try
            {
                SearchCountiesAsync(CountySearch.CountyName);
            }
            catch (Exception)
            {
                /*ByNameErrorString*/
                
            }
        }

        @* {SCENARIO #3: COUNTY SEARCH INITIALLY USED FIRST AND RETRIED WITH COUNTYDROPDOWN HAVING BEEN POPOULATED BUT STATE ID HAVING AN EMPTY STRING}*@
        @if ((CountySearch.CountyName != null) &&
        (CountyDropdown.CountyName != string.Empty) && (CountyDropdown.CountyName is null) &&
        (CountyDropdown.StateId != string.Empty))
        {
            try
            {
                SearchCountiesAsync(CountySearch.CountyName);
            }
            catch (Exception)
            {
                /*ByNameErrorString*/
                
            }
        }

        @* {SCENARIO #4: COUNTYDROPDOWN USED AS SECONDARY WITH COUNTY SEARCH BAR / STATE ID NOT EMPTY OR NULL @*(CountySearch.CountyName != null) &&*@
        @if ((CountyDropdown.CountyName != null) && (CountyDropdown.CountyName != string.Empty) &&
        (CountySearch.CountyName != string.Empty) &&
        (CountyDropdown.StateId != null))
        {
            CountySearch.CountyName = null;
            try
            {
                SearchCountiesAsync(CountySearch.CountyName);
            }
            catch { }
        }
    
    </div>
</EditForm>
