         (CountyDropdown.CountyName != string.Empty) && (CountyDropdown.CountyName is null) &&
         (CountyDropdown.StateId is null)) { /*HIDES STATE TEXTBOX*/ }

        @* {SCENARIO #2: COUNTY SEARCH AS INITIAL USE}*@
        @if ((CountySearch.CountyName != null) &&
         (CountyDropdown.CountyName != string.Empty) && (CountyDropdown.CountyName is null) &&
         (CountyDropdown.StateId is null))
        {
            // POPULATES STATE TEXTBOX
            <InputText id="StateId" class="form-control" placeholder="State ID" @bind-Value="CountySearch.StateId" />
            // BRINGS OVER CORRESPONDING STATE ID
            CountySearch.StateId = State;
