<EditForm Model="@CountyDropdown">
    <div class="container">
        <select id="ListAllCounties"
                @bind="selectedCountyId"
                @bind:event="OnCountySelected">
            <option value="0">Select County</option>
            @foreach (var item in ListAllCounties)
            {
                <option value="@item.Id">@item.CountyName</option>
            }
        </select>
        <InputSelect id="countyDropdownTextbox" @bind-Value="@CountyDropdown.CountyName" class="form-control"></InputSelect>
    </div>
    @* {SCENARIO #1: NULL CHECKS INITIAL STATE OF THE APPLICATION} POPULATES COUNTY DROPDOWN *@
    @if (
        (CountySearch.CountyName is null) &&
    (CountyDropdown.CountyName != string.Empty) && (CountyDropdown.CountyName is null) &&
    (CountyDropdown.StateId is null))
    {
        //
        if (CountyDropdown.CountyName != string.Empty)
        {
            CountySearch.CountyName = null;
            //
            if (ListAllCounties.Count == 0)
            {
                try
                {
                    /*await*/
                    RetrieveAllCountiesAsync();
                    //PopulateCountyDropdown();

                }
                catch (Exception)
                {
                    
                    throw;
                }
            }
            //
            if (ListAllCounties.Count > 0)
            {
                //
                foreach (var cnty in ListAllCounties)
                {
                    //
                    try
                    {
                        <option value="@cnty.CountyName">@cnty.CountyName</option>
                    }
                    catch
                    { }
                    //TODO: SEE ABOUT DISPLAYING
                }
            }
        }
    }
</EditForm>

