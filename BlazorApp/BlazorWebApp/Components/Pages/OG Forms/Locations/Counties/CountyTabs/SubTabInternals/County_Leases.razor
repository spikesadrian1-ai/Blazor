@*<Paginations TotalPagesQuantity="totalPageQuantity" CurrentPage="currentPage" Radius="2"
             SelectedPage="SelectedPage">
</Paginations>*@

@code
{
    string countyId = "MONT";

    private int totalPageQuantity;
    private int currentPage = 1;

    //private IEnumerable<LeasesWithinCounty> GetLeasesWithinCounty = Array.Empty<LeasesWithinCounty>(); string errorString;
    List<LeasesWithinCounty> GetLeasesWithinCounty { get; set; }

    string errorString;

    protected override async Task OnInitializedAsync()
    {
        var request = new HttpRequestMessage(HttpMethod.Get,
        // TODO: MAKE CUSTOM PROC FOR LEASES WITHIN A CERTAIN COUNTY
        /// API url goes inside ""  \\// "http://localhost:1397/"); OR "https://localhost:44300/"); OR "https://localhost:44300/api/LeasesInsideDistrict/GetAllLeases/");
        _config["API_URL"] + $"LeaseMainForm2/SearchAllLeasesByCountyId/{countyId}");

        var client = _clientFactory.CreateClient();

        HttpResponseMessage response = await client.SendAsync(request);

        if (response.IsSuccessStatusCode)
        {
            using var responseStream = await response.Content.ReadAsStreamAsync();
            GetLeasesWithinCounty = await JsonSerializer.DeserializeAsync<List<LeasesWithinCounty>>(responseStream);

            errorString = null;
        }
        else
        {
            errorString = $"There was an error getting Districts: { response.ReasonPhrase }";
        }
    }
}
