@page "/PaymentObligationsInfo"

@* @using BlazorWebApp.Pages.OG_Forms.Properties.Tracts.TractTabs.SubTabInternals.TractMorePage *@

@using ApplicationLayer.Entities.Payments
@using ApplicationLayer.Entities.Locations.Regions
@using ApplicationLayer.Entities.Locations.States

@inject IJSRuntime jsRuntime
@inject Microsoft.Extensions.Configuration.IConfiguration _config
@inject IHttpClientFactory _clientFactory

@inherits TractMainPageBase
@* TractMorePageBase *@

@{
    /* public */
    PaymentObligations paymentObligationsEntity = new PaymentObligations();
    var showClass = IsVisible ? "d-block" : "d-none";

}

<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width, initial-sclae=1">
<link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Roboto|Varela+Round" />
<link rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Icons" />
<link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css" />
<link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css" />
<link href="~/css/style.css" rel="stylesheet" />

<div class="modal p-3 @showClass" data-bs-autohide="true" data-bs-delay="5000" style="align-self:center; ">
    <div class="container position-relative"
         style="overflow:scroll;
                        -webkit-overflow-scrolling:auto;
                        justify-content:left;
                        border-width:medium;
                        width:-webkit-fit-content;
                        height:450px;">

        <div class="modal-body" style="align-self:center">
            <div class="modal-content align-content-center">
                <div class="modal-header">
                    <button type="button" class="btn-close" aria-label="Close" @onclick="Close"></button>
                </div>
                <div class="card" style="align-content:center; width:-webkit-fit-content; height:max-content">
                    <div class="card-header">
                        <strong class="me-auto">New PaymentObligationsComponent Form for Tract @($"{LeaseID}")</strong>
                    </div>
                    <div class="card-body m-auto" style="width:auto">
                        <form method="post" class="mt-3" enctype="multipart/form-data">
                            <div class="form-row">
                                <br />
                                <button type="submit" class="btn btn-primary" style="width:150px;" @*onclick="OnPostCreateTract" *@> Save </button>
                                <button type="submit" class="btn btn-danger" style="width:150px;" @*onclick="OnPostCreateTract" *@>Delete</button>
                                <button type="button" class="btn btn-primary" style="width:150px;" @*onclick="OnPostCreateTract" *@>Print</button>
                                <div class="col-xl-12 col-lg-6">
                                    <br />
                                    <div class="card accent-card mb-3">
                                        <div class="card-header">PAYMENT INFORMATION</div>
                                        <div class="card-body">
                                            <div class="col-12 col-lg-6">
                                                <label>Payee ID</label>
                                                <InputSelect @bind-Value="paymentObligationsEntity.PayeeId" class="form-control" placeholder="Select a Owner"></InputSelect>
                                                <br />
                                                <label>Payment Type</label>
                                                <InputSelect @bind-Value="paymentObligationsEntity.PaymentType" class="form-control" placeholder="1/16 or .0025"></InputSelect>

                                                <label>Responsible Party</label>
                                                <InputSelect @bind-Value="paymentObligationsEntity.ResponsibleParty" class="form-control" placeholder="0.00000000"></InputSelect>
                                                <br />
                                                <label>Beginning Due Date</label>
                                                <InputDate @bind-Value="paymentObligationsEntity.BeginningDueDate" class="form-control" placeholder="Burden Type"></InputDate>
                                                <br />
                                                <label>Period Frequency</label>
                                                <InputNumber @bind-Value="paymentObligationsEntity.PeriodFrequency" class="form-control" placeholder="0.00"></InputNumber>
                                                <br />
                                                <label>Ending Date</label>
                                                <InputDate @bind-Value="paymentObligationsEntity.EndingDate" class="form-control" placeholder="Burden Type"></InputDate>
                                                <br />
                                                <label>Net Amount</label>
                                                <InputNumber @bind-Value="paymentObligationsEntity.NetAmount" class="form-control" placeholder="0.00"></InputNumber>
                                                <br />
                                                <label>Recommendation</label>
                                                <InputSelect @bind-Value="paymentObligationsEntity.Recommendation" class="form-control" placeholder="Notes"></InputSelect>
                                                <br />
                                            </div>
                                        </div>
                                        <div class="card-header">BANK INFORMATION</div>
                                        <div class="card-body">
                                            <div class="col-12 col-lg-6">
                                                <label>Bank ID</label>
                                                <InputSelect @bind-Value="paymentObligationsEntity.BankId" class="form-control" placeholder="(ex. JPMC001)"></InputSelect>
                                                <br />
                                                <label>Bank Account No</label>
                                                <InputNumber @bind-Value="paymentObligationsEntity.BankAccountNo" class="form-control" placeholder="(ex. 0000-00000000)"></InputNumber>
                                                <br />
                                                <label>Additional Bank Fees</label>
                                                <InputNumber @bind-Value="paymentObligationsEntity.AdditionalBankFees" class="form-control" placeholder="0.00"></InputNumber>
                                            </div>
                                            <div class="row">
                                                @* <InputSelect @bind-Value="EntityID" class="form-control" placeholder="0.00000000"></InputSelect> *@
                                                <br />
                                                <InputText @bind-Value="LeaseID" class="form-control" placeholder="LeaseId"></InputText>
                                                <br />
                                                <InputText @bind-Value="TractID" class="form-control" placeholder="TractId"></InputText>
                                                <br />
                                                @* <InputNumber @bind-Value="EasementID" class="form-control" placeholder="EasementId"></InputNumber> *@
                                                <br />
                                                @* <InputSelect @bind-Value="WellID" class="form-control" placeholder="WellId"></InputSelect> *@
                                                <br />
                                                @* <InputNumber @bind-Value="RowID" class="form-control" placeholder="RowId"></InputNumber> *@
                                                <br />
                                                @* <InputNumber @bind-Value="SuaID" class="form-control" placeholder="SuaId"></InputNumber> *@
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>


