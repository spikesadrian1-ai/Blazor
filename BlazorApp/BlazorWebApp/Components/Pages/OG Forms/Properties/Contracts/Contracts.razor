@page "/contracts"
@page "/contracts/{EntityID}/{IdFromListView}"

@inherits ContractMainBase

<div class="tab-content" align="center">
    <TabControl>
        <TabPage Text="MAIN">
            <Main EntityID="@EntityID"
                  NewContractID="@NewContractID"
                  InitialState="@InitialState"
                  IdFromListView="@IdFromListView">
            </Main>
        </TabPage>
        <TabPage Text="MORE">
            <More EntityID="@EntityID"
                  NewContractID="@NewContractID"></More>
        </TabPage>
        <TabPage Text="LOCATION">
            <Location EntityID="@EntityID"
                      NewContractID="@NewContractID"></Location>
        </TabPage>
        <TabPage Text="DATES">
            <BlazorWebApp.Components.Pages.OG_Forms.Properties.Contracts.Tabs.Dates.Dates EntityID="@EntityID"
                   NewContractID="@NewContractID"></BlazorWebApp.Components.Pages.OG_Forms.Properties.Contracts.Tabs.Dates.Dates>
        </TabPage>
        <TabPage Text="GAS MARKET">
            <GasMarket EntityID="@EntityID"
                       NewContractID="@NewContractID"></GasMarket>
        </TabPage>
        <TabPage Text="SEISMIC OPTION">
            <Seismic EntityID="@EntityID"
                     NewContractID="@NewContractID"></Seismic>
        </TabPage>
        <TabPage Text="OTHER">
            @*     <Other EntityID="@EntityID"
                          NewContractID="@NewContractID"></Other> *@
        </TabPage>
        <TabPage Text="CROSS-REFS">
            <ContractCrossRefs EntityID="@EntityID"
                       NewContractID="@NewContractID"></ContractCrossRefs>
        </TabPage>
    </TabControl>
</div>

