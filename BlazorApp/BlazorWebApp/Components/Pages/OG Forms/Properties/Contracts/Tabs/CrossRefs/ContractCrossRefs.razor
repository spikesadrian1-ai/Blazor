@* @page "/Well" *@
@* @page "/OwnerInfo/{OwnerID}" *@

@using ApplicationLayer.Entities.Owners

@inherits ContractMainBase

@{

}


<EditForm Model="@contractMain">

    <div class="container border border-top border-bottom m-1 auto">
        @* border-dark *@
        <div class="card accent-card">
            <div class="form-row">
                <div class="col-3" style="align-items:center; align-content:center;">
                    <div class="card-body">
                        <div class="form-row" style="">
                            <button type="submit" class="btn btn-primary form-control" style="width:300px;"
                                    @onclick="() => ShowRelatedContracts()">
                                Related Contracts
                            </button>
                        </div>
                        <div class="form-row" style="">
                            <button type="submit" class="btn btn-primary" style="width:300px;"
                                    @onclick="ShowRelatedLeases">
                                Related Leases
                            </button>
                        </div>
                        <div class="form-row" style="">
                            <button type="submit" class="btn btn-primary" style="width:300px;"
                                    @onclick="ShowRelatedPayments">
                                Payment History
                            </button>
                        </div>
                        <div class="form-row" style="">
                            <button type="submit" class="btn btn-primary" style="width:300px;"
                                    @onclick="ShowRelatedTwnRngSections">
                                Twn-Rng-Sec Info
                            </button>
                        </div>
                        <div class="form-row" style="">
                            <button type="submit" class="btn btn-primary" style="width:300px;"
                                    @onclick="ShowRelatedTitleHistory">
                                Title History
                            </button>
                        </div>
                        <div class="form-row" style="">
                            <button type="submit" class="btn btn-primary" style="width:300px;"
                                    @onclick="ShowRelatedRevenueHistory">
                                Revenue History
                            </button>
                        </div>
                        <div class="form-row" style="">
                            <button type="submit" class="btn btn-primary" style="width:300px;"
                                    @onclick="ShowRelatedParties">
                                Related Parties
                            </button>
                        </div>
                        <div class="form-row" style="">
                            <button type="submit" class="btn btn-primary" style="width:300px;"
                                    @onclick="ShowRelatedDoiDecks">
                                DOI Decks
                            </button>
                        </div>
                        @* <div class="form-row" style="">
                            <button type="submit" class="btn btn-primary" style="width:300px;" 
                            @onclick="OnPostCreateTract" > Prod. Purchasers </button>
                        </div>
                        <div class="form-row" style="">
                            <button type="submit" class="btn btn-primary" style="width:300px;" 
                            @onclick="OnPostCreateTract" > A.P.I's' </button>
                        </div> *@
                    </div>
                </div>
                <div class="col-9">
                    <div class="form-row">
                        <div class="card-body border border-dark" style="width:900px; height:500px;">
                            @if (showContractComponent == true)
                            {
                                <RelatedContractCrossRefs />
                            }
                            @if (showLeaseComponent == true)
                            {
                                <RelatedContractLeases />
                            }
                            @if (showPayments == true)
                            {
                                <RelatedContractPayments />
                            }
                            @if (showTwnRngSecs == true)
                            {
                                <RelatedContractTwnRngSections />
                            }
                            @if (showTitleHistory == true)
                            {
                                <RelatedContractTitles />
                            }
                            @if (showRevenueHistory == true)
                            {
                                <RelatedContractRevenueHistory />
                            }
                            @if (showParties == true)
                            {
                                <RelatedContractPartys />
                            }
                            @if (showDOIDecks == true)
                            {
                                <RelatedContractDoiDecks />
                            }
                            @* @if (showApiHistory == true)
                            {
                                <RelatedApiHistory />
                            }
                            @if (showProductionPurchasers == true)
                            {
                                <RelatedProductionPurchasers />
                            } *@
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</EditForm>


