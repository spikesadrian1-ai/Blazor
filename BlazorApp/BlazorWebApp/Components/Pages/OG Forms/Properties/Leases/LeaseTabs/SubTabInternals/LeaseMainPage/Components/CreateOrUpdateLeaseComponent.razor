@page "/CreateOrUpdateLeaseComponent"
@page "/CreateOrUpdateLeaseComponent/{LeaseID}"


@using ApplicationLayer.Entities.DropDownList
@using ApplicationLayer.Entities.Locations.Regions
@using ApplicationLayer.Entities
@using ApplicationLayer.Entities.Locations.States
@using ApplicationLayer.Services.Locations.CountyServices
@using ApplicationLayer.Services.DropdownLists
@using ApplicationLayer.Services.Assets.Tracts.TractStatus

@inject Microsoft.Extensions.Configuration.IConfiguration _config
@inject IHttpClientFactory _clientFactory

@inherits TractMainPageBase

<br />


<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width, initial-sclae=1">
<link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Roboto|Varela+Round" />
<link rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Icons" />
<link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css" />
<link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css" />
<link href="~/css/style.css" rel="stylesheet" />

@{
    LeaseMainForm2? LeaseModel = new LeaseMainForm2();
    LeaseModel.LeaseId = @LeaseID.ToString();
    ReturnedLease_ID = @LeaseID.ToString();
    ReturnedLease_ID.ToString();
}

<CascadingValue Name="@LeaseID" Value="@LeaseID.ToString()"></CascadingValue>

@code {
    #region CASCADING PARAMS
    [Parameter] public string? LeaseID { get; set; } = string.Empty;
    #endregion CASCADING PARAMS

    //public string? ReturnedLease_ID { get; set; } = string.Empty;

    public string ReturnedLease_ID
    {
        // get => ReturnedLease_ID;
        // set {
        //     LeaseID = value; }

        get => LeaseID;
        set
        {
            LeaseID = value;
        }
    }
}

<BackButtonComponent></BackButtonComponent>

@if (ReturnedLease_ID == null)
{
    <div class="form-control" align="center"> <h3>New Lease Creation </h3> </div>
}

@if (ReturnedLease_ID != null)
{
    <div class="" align="center"> <h3>Lease Information for Lease ID: @($"{ReturnedLease_ID}")</h3> </div>
}

<div class="row" align="left">
    <br />
    <NavLink class="btn btn-primary form-control" style="width:auto;" href="@($"/ListOfLeasesComponent")">
        View Leases
    </NavLink>
    <br />
</div>

<form method="post">

