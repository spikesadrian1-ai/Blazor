    <InputText id="ReturnedLease_ID" class="form-control" placeholder="Lease ID" @bind-Value="@LeaseID" />
    <InputText id="ReturnedLease_ID2" class="form-control" placeholder="Lease ID" @bind-Value="@LeaseID" />
    <InputText id="ReturnedLease_ID3" class="form-control" placeholder="Lease ID" @bind-Value="@ReturnedLease_ID" /> *@

    <div class="form-row">
        <div class="card p-1" style="max-width:fit-content">
            <div class="border p-1 nt-4">
                <h4 class="text-primary pl-sm-1">Main</h4>
                <input type="text" asp-for="@ReturnedLease_ID.ToString()" placeholder="Lease ID" data-bind=@($"{ReturnedLease_ID}") />
                <input type="text" asp-for="@LeaseModel.LeaseId.ToString()" placeholder="Lease ID" data-bind="@($"{ReturnedLease_ID}")" />
                <input type="text" asp-for="@($"{ReturnedLease_ID}")" placeholder="Lease ID" data-bind="@($"{ReturnedLease_ID}")" />
                <input type="text" placeholder="Lease ID" data-bind="@LeaseID" />
                Lease ID:
                <br />
                <input type="text" asp-for="@LeaseModel.LeaseId" placeholder="Lease ID" />
                Lease Date:
                <input type="date" asp-for="@LeaseModel.LeaseDate" placeholder="Lease Date" />
                Effective Date:
                <input type="date" asp-for="@LeaseModel.EffectiveDate" placeholder="Effec. Date" />
                Primary Term:
                <input type="range" asp-for="@LeaseModel.PrimaryTerm" placeholder="Primary Term" />
                <br />
                Expire Date:
                <br />
                <input type="date" asp-for="@LeaseModel.ExpireDate" placeholder="Expire Date" />
                Term Option:
                <input type="number" asp-for="@LeaseModel.TermOption" placeholder="Term Option" />
                Second Expiration Date:
                <input type="date" asp-for="@LeaseModel.SecondExpirationDate" placeholder="Second Exp. Date" />
                Active:
                <input type="checkbox" asp-for="@LeaseModel.Active" name="active"
                       value="active" />
                @*  &nbsp; @(active ? "test" : "Active") *@
                <br />
                <br />
                <input type="text" asp-for="@LeaseModel.LessorId" placeholder="Lessor ID" />
                <input type="text" asp-for="@LeaseModel.LeaseName" placeholder="Lease Name" />
                <input type="text" asp-for="@LeaseModel.AlternateLeaseName" placeholder="Alt. Lease Name" />
                <input type="text" asp-for="@LeaseModel.LesseeId" placeholder="Lessee ID" />
                <br />
                <br />
                <input type="text" asp-for="@LeaseModel.ConsiderationAmount" placeholder="Total Consideration (0.00)" />
                <input type="text" asp-for="@LeaseModel.RoyaltyInterest" placeholder="ROY Amount (0.00000000)" />
                <input type="text" asp-for="@LeaseModel.ORRI" placeholder="ORRI Amount (0.00000000)" />
                <input type="text" asp-for="@LeaseModel.GrossAcres" placeholder="Gross Acres (0.00000000)" />
                <input type="text" asp-for="@LeaseModel.NetAcres" placeholder="Net Acres (0.00000000)" />
            </div>
        </div>
        <hr />
        <div class="card p-1" style="max-width:fit-content">
            <div class="border p-1 nt-4">
                <h5 class="text-primary pl-1">Options</h5>
                <div class="card-columns">
                    Paid Up:
                    <input type="checkbox" asp-for="@LeaseModel.PaidUp" name="PaidUp" value="Paid Up" />
                    <br />
                    Producing:
                    <input type="checkbox" asp-for="@LeaseModel.Producing" name="Producing" />
                    <br />
                    Unitized:
                    <input type="checkbox" asp-for="@LeaseModel.Unitized" name="Unitized" />
                </div>
                <div class="card-columns">
                    Renewal Lease:
                    <input type="checkbox" asp-for="@LeaseModel.RenewalLease" name="RenewalLease" />
                    <br />
                    Top Lease:
                    <input type="checkbox" asp-for="@LeaseModel.TopLease" name="TopLease" />
                    <br />
                    Validated:
                    <input type="checkbox" asp-for="@LeaseModel.Validated" name="Validated" />
                </div>
                <div class="card-columns">
                    Pending:
                    <input type="checkbox" asp-for="@LeaseModel.Pending" name="Pending" />
                    <br />
                    Ok To Pay:
                    <input type="checkbox" asp-for="@LeaseModel.OkToPay" name="OkToPay" />
                    <br />
                </div>
            </div>
        </div>
        <div class="card p-1" style="max-width:fit-content">
            <div class="border p-1 nt-4">
                <h5 class="text-primary pl-1">Location</h5>
                @* <input type="text" asp-for="StateID" placeholder="State ID" /> *@
                <select asp-for="StateID" role="presentation" class="form-control " asp-items="Html.GetEnumSelectList<States>()">
                    <option value="">Choose a state</option>
                    @* @Html.ValidationMessage("state") *@
                </select>
                <br />
                <br />
                @* <input type="text" asp-for="CountyID" placeholder="County ID " /> *@
                <select asp-for="CountyID" role="presentation" class="form-control">
                    <option value="">Choose a state</option>
                    @*  @Html.ValidationMessage("state") *@
                </select>
            </div>
        </div>
        <hr />
        <div class="card p-1" style="max-width:fit-content">
            <div class="border p-1 nt-4">
                <h5 class="text-primary pl-1">Legal Description</h5>
                <input type="text" style="width:750px; height:125px" asp-for="@LeaseModel.LegalDescription" />
            </div>
        </div>
    </div>
    <br />
    <div class="card p-1">
        <div class="border p-1 nt-4">
            <h5 class="text-primary pl-1">Create New Lease</h5>
            <input type="text" asp-for="ConsiderationAmount" placeholder="Total Consideration (0.00000000)" />
            <input type="text" asp-for="RoyaltyInterest" placeholder="ROY Amount (0.00000000)" />
            <input type="text" asp-for="ORRI" placeholder="ORRI Amount (0.00000000)" />
            <input type="text" asp-for="GrossAcres" placeholder="Gross Acres (0.00000000)" />
            <input type="text" asp-for="NetAcres" placeholder="Net Acres (0.00000000)" />
        </div>
    </div>
    <br />
    <button class="btn btn-primary" style="width:150px;" @onclick="AddNewCountyAsync">Save</button>
    <button type="submit" class="btn btn-primary" style="width:150px;" @onclick="AddNewCountyAsync">Delete</button>
    <button type="submit" class="btn btn-primary" style="width:150px;" @onclick="AddNewCountyAsync">Print</button>
    @* <button type="submit" class="btn btn-primary" style="width:150px;" asp-page="/OG Forms/Property/Leases/ViewLease">View Leases</button> *@
    <br />
</form>
