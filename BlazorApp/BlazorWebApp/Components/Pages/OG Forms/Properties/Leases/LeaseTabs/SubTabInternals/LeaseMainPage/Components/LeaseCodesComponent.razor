                                                                    <option value="0">Lease Type</option>
                                                                    <option value="1">Full Interest</option>
                                                                    <option value="2">Proportionately Reduced</option>

                                                                </select>
                                                                <div class="invalid-feedback">
                                                                    <span asp-validation-for="CountyID"></span>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </main>

                                                @* <div class="col-6">
                                                    <div class="border p-1 nt-4">

                                                        <select id="ListOfLeaseFormTypesDropdown" class="form-control ">
                                                            <option value="0">Choose a Responsible Party</option>
