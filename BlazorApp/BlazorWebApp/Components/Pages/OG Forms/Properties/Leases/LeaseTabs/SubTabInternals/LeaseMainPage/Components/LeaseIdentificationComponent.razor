<div class="modal p-3 @showClass" data-bs-autohide="true" data-bs-delay="5000" style="align-self:center; ">
    <div class="container position-relative"
         style="overflow:auto;
                        justify-content:left;
                        border-width:medium;
                        width:-webkit-fit-content;
                        height:auto;">

        <div class="modal-body" style="align-self:center">
            <div class="modal-content align-content-center">
                <div class="modal-header">
                    <button type="button" class="btn-close" aria-label="Close" @onclick="Close"></button>
                </div>
                <div class="card" style="align-content:center; width:-webkit-fit-content; height:max-content">
                    <div class="card-header">
                        <strong class="me-auto">Lease Identification for @($"{leaseModel.LeaseId}")</strong>
                    </div>
                    <div class="card-body m-auto" style="width:auto">
                        <form method="post" class="mt-3" enctype="multipart/form-data">
                            <div class="form-row">
                                <br />
                                <button type="submit" class="btn btn-primary" style="width:150px;" @*onclick="OnPostCreateTract" *@> Save </button>
                                <div class="col-xl-12 col-lg-6">
                                    <br />
                                    <div class="card accent-card mb-3">
                                        <div class="card-body">
                                            <EditForm Model="@leaseModel">
                                                <div class="border p-1 nt-4">
                                                    <div class="container-fluid">

                                                        <div class="form-row">
                                                            <label>Acquisition</label>
                                                            <div class="col">
                                                                <InputText @bind-Value="@leaseModel.AcquisitionCode" class="form-control" placeholder="Acquisition Code"></InputText>
                                                            </div>
                                                            <label>Lease Type</label>
                                                            <div class="col">
                                                                <InputText @bind-Value="@leaseModel.LeaseType" class="form-control" placeholder="Lease Typew No."></InputText>
                                                            </div>
                                                            <label>Lease Status</label>
                                                            <div class="col">
                                                                <InputText @bind-Value="@leaseModel.LeaseStatus" class="form-control" placeholder="Lease Ststus No."></InputText>
                                                            </div>
                                                            <label>Instrument</label>
                                                            <div class="col">
                                                                <InputText @bind-Value="@leaseModel.InstrumentCode" class="form-control" placeholder="Instrument No."></InputText>
                                                            </div>
                                                            <label>Payout Code</label>
                                                            <div class="col">
                                                                <InputText @bind-Value="@leaseModel.PayoutCode" class="form-control" placeholder="Payout Code"></InputText>
                                                            </div>
                                                        </div>

                                                    </div>
                                                </div>
                                            </EditForm>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


@code {
    #region CASCADE PARAMS

    #region CASCADING PARAMS
    //[Parameter] public string? LeaseID { get; set; } = string.Empty;
    #endregion CASCADING PARAMS

    #endregion CASCADE PARAMS



    [Parameter]
    public bool IsVisible { get; set; }

    [Parameter]
    public EventCallback<bool> IsVisibleChanged { get; set; }

    [Parameter]
    public string? HeaderText { get; set; }

    [Parameter]
    public string? BodyText { get; set; }

    public void Show(string bodyText, string headerText = "")
    {
        HeaderText = headerText;
        BodyText = bodyText;
        IsVisible = true;
        StateHasChanged();
    }

    private void Close()
    {
        HeaderText = string.Empty;
        BodyText = string.Empty;
        IsVisible = false;
        StateHasChanged();
    }
}