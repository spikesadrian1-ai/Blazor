<EditForm Model="@leaseModel">

    <div class="container border border-top border-bottom m-1 auto">
        @* border-dark *@
        <div class="card accent-card">
            <div class="card-body">
                <div class="card-header form-control-sm">
                    @{
                        if (InitialState == false)
                        {
                            <strong class="me-auto">Information for Lease: @IdFromListView.ToString()</strong>
                        }
                        else
                        if ((InitialState == true) && (!string.IsNullOrEmpty(IdFromListView)))
                        {
                            InitialState = false;
                            <strong class="me-auto">Information for Lease: @IdFromListView.ToString()</strong>
                        }
                        else
                        if (InitialState == true)
                        {

                            <strong class="me-auto">New Lease Information Form</strong>
                        }
                    }
                </div>
            </div>
            <div class="card-body">
                <div class=form-row>
                    <div class="col-4">
                        <label>Lease ID</label>
                        @{
                            if (InitialState == true)
                            {
                                <InputText @bind-Value="leaseModel.LeaseId"
                                class="form-control" placeholder="Enter New Lease ID"></InputText>
                                <DataAnnotationsValidator></DataAnnotationsValidator>
                                <ValidationSummary></ValidationSummary>
                            }
                            else
                            if (InitialState == false)
                            {
                                /// COMMENT: USER HAS CHOSEN A LEASE FROM LIST COMPONENT
                                var testName2 = "";
                                var testName3 = "";

                                if (leaseModel.LeaseId == null)
                                {
                                    testName2 = IdFromListView;
                                    leaseModel.LeaseId = IdFromListView;
                                    //getLeaseInfo.Id = int.Parse(LeaseTablePK);
                                }
                                else
                                {
                                    testName2 = leaseModel.LeaseId.ToString();
                                    leaseModel.LeaseId = IdFromListView;
                                    getLeaseInfo.LeaseId = IdFromListView;
                                }

                                /// COMMENT: WHEN USER HAS ALREADY SELECTED A TRACT THEN VIEWED A LEASE AND HAS NOW CHOSEN TO VIEW A DIFFERENT TRACT
                                /// PURPOSE: TO ENSURE LEASE MODEL HAS BEEN CLEARED AND REHYDRATED WITH THE "NEW" ONE
                                /// PROBLEM SOLVED: LOSS/MISSING DATA

                                testName3 = getLeaseInfo.LeaseId.ToString();

                                /// COMMENT: CHECK VARIABLES AND IF DIFF THEN USE NEW VARIABLE INSTEAD
                                if (testName2 != testName3)
                                {
                                    //RESET TABLE ID
                                    // getLeaseInfo.Id = 0;
                                    // //ID = int.Parse(LeaseTablePK);
                                    // getLeaseInfo.Id = ID;
                                    getLeaseInfo.LeaseId = getLeaseInfo.LeaseId.ToString();
                                    leaseModel.LeaseId = IdFromListView; //getTracts.TractId.ToString();
                                    //PopulateFormBasedOnEntityID(getLeaseInfo);
                                    //Task.Run<LeaseMainForm2>(PopulateFormBasedOnEntityID(getLeaseInfo).
                                    //Task.WhenAll(PopulateFormBasedOnEntityID(getLeaseInfo)/* , PopulateDropdowns() */);
                                }
                                else
                                // if (testName2 == testName3)
                                // {
                                        
                                // }

                                //   SATE MANAGEMENT: CHECKS IF LEASE ID IS THE SAME
                                if (IdFromListView == leaseModel.LeaseId)
                                {
                                    getLeaseInfo.LeaseId = getLeaseInfo.LeaseId.ToString();
                                    leaseModel.LeaseId = IdFromListView; //getTracts.TractId.ToString();
                                    Task.WhenAll(PopulateFormBasedOnEntityID(getLeaseInfo)/* , PopulateDropdowns() */);

                                }
                                // else
                                // if (IdFromListView != leaseModel.LeaseId)
                                // {
                                    
                                // }

                                <InputText @bind-Value="leaseModel.LeaseId"
                                class="form-control" placeholder="Enter New Lease ID"
                                ></InputText>
                                <DataAnnotationsValidator></DataAnnotationsValidator>
                                <ValidationSummary></ValidationSummary>


                            }
                        }
                    </div>

                    <div class="col-2">
                        <label>Date</label>
                        <InputDate @bind-Value="leaseModel.LeaseDate" class="form-control" placeholder="mm/dd/YYYY"></InputDate>
                    </div>

                    <div class="col-2">
                        <label>Effective</label>
                        <InputDate @bind-Value="leaseModel.EffectiveDate" class="form-control" placeholder="mm/dd/YYYY"></InputDate>
                    </div>

                    <div class="col-2">
                        <label>Expires</label>
                        <InputDate @bind-Value="leaseModel.ExpirationDate" class="form-control" placeholder="mm/dd/YYYY"></InputDate>
                    </div>

                    <div class="col-1">
                        <label>Option</label>
                        <InputNumber @bind-Value="leaseModel.TermOption" class="form-control" placeholder="0"></InputNumber>
                    </div>

                    <div class="col-1">
                        <label>Term</label>
                        <InputNumber @bind-Value="leaseModel.PrimaryTerm" class="form-control" placeholder="0"></InputNumber>
                    </div>

                </div>

            </div>

            <div class="form-row">

                <div class="col">
                    <div class="card-body">
                        <div class="card-header">Location(s)</div>
                    </div>
                    <div class="card-body">

                        <div class="form-row">

                            <div class="col-6">
                                <div class="border p-1 nt-4">
                                    <select asp-for="StateID" class="form-control " asp-items="Html.GetEnumSelectList<States>()">
                                        <option value="">Choose a State</option>
                                    </select>
                                    <select asp-for="CountyID" class="form-control">
                                        <option value="">Choose a County</option>
                                    </select>
                                </div>
                            </div>

                            <div class="col-6">
                                <div class="border p-1 nt-4">
                                    @if (InitialState == true)
                                    {
                                        <select id="ListAllCounties" class="form-control" style="align-self:center; width:275px;">
                                            <option value="0">Select County</option>
                                            @foreach (var item in ListAllCounties)
                                            {
                                                <option value="@item.Id">@item.CountyName</option>
                                            }
                                        </select>

                                        <select id="ListAllCounties" class="form-control" style="align-self:center; width:275px;">
                                            <option value="0">Select State</option>
                                            @foreach (var item in ListOfStates)
                                            {
                                                <option value="@item.Id">@item.State</option>
                                            }
                                        </select>
                                    }
                                    else
                                    if (InitialState == false)
                                    {
                                        <select id="ListAllCounties" class="form-control" style="align-self:center; width:275px;">
                                            <option value="@leaseModel.CountyId">@leaseModel.CountyId</option>
                                            @foreach (var item in ListAllCounties)
                                            {
                                                <option value="@item.Id">@item.CountyName</option>
                                            }
                                        </select>

                                        <select id="ListAllCounties" class="form-control" style="align-self:center; width:275px;">
                                            <option value="@leaseModel.StateId">@leaseModel.StateId</option>
                                            @foreach (var item in ListOfStates)
                                            {
                                                <option value="@item.Id">@item.State</option>
                                            }
                                        </select>
                                    }
                                </div>
                            </div>

                        </div>

                    </div>

                </div>

                <div class="col">
                    <div class="card-body">
                        <div class="card-header">Lessor / Lessee</div>
                    </div>
                    <div class="card-body">

                        <div class="form-row">

                            <div class="col-6">
                                <div class="border p-1 nt-4">
                                    @* <label>Lessor ID</label> *@
                                    @{
                                        //TODO: ADD SELECT DROPDOWN
                                    }
                                    @* <div class="container"> *@
                                    <select id="ListOfOwners"
                                    class="form-control"
                                    @bind="@leaseModel.LessorId"
                                    @bind:event="OnCountySelected">
                                        <option value="0">Select a Lessor</option>
                                        @* @foreach (var item in ListAllCounties)
                                        {
                                        <option value="@item.Id">@item.CountyName</option>
                                        } *@
                                    </select>
                                    @* <br /> *@
                                    <input type="text" value="@leaseModel.LeaseName" class="form-control" placeholder="Lease Name" />

                                </div>
                            </div>

                            <div class="col-6">
                                <div class="border p-1 nt-4">
                                    <input type="text" value="@leaseModel.AlternateLeaseName" class="form-control" placeholder="Alt. Lease Name" />
                                    @* <br /> *@
                                    <select id="ListOfOwners"
                                    class="form-control"
                                    @bind="@leaseModel.LesseeId"
                                    @bind:event="OnCountySelected">
                                        <option value="0">Select a Lessee</option>
                                        @* @foreach (var item in ListAllCounties)
                                        {
                                        <option value="@item.Id">@item.CountyName</option>
                                        } *@
                                    </select>
                                </div>
                            </div>

                        </div>

                    </div>

                </div>

            </div>

            <div class="card-body legalDescriptionLabel" id="" title="Legal Description">
                <div class="card-header">Legal Description</div>
                <div class="form-row">

                    <div class="col">
                        <div class="border p-1 nt-4">
                            <InputTextArea @bind-Value="@leaseModel.LegalDescription" class="form-control" placeholder=""></InputTextArea>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>

</EditForm>
