@* <a class="btn m-1" style="color: aqua; font-size: 3rem; " @onclick="RedirectPage">DATES</a> *@
@* <LeaseDates LeaseID="LeaseID"></LeaseDates> *@
@* <LeaseDates LeaseID="@LeaseID"
               @ref="popupRef" /> *@



<div class="modal p-3 @showClass" data-bs-autohide="true" data-bs-delay="5000" style="align-self:center; ">
    <div class="container position-relative"
         style="overflow:auto;
                        justify-content:left;
                        border-width:medium;
                        width:-webkit-fit-content;
                        height:auto;">

        <div class="modal-body" style="align-content:center; width:-webkit-fit-content; height:auto;">

            <div class="modal-content align-content-center">

                <div class="modal-header">
                    <button type="button" class="btn-close" aria-label="Close" @onclick="Close"></button>
                </div>

                <div class="card" style="align-content:center; width:-webkit-fit-content; height:max-content;">

                    <div class="card-header">
                        <strong class="me-auto">Other Costs for @($"{leaseModel.LeaseId}")</strong>
                    </div>

                    <div class="card-body m-auto" style="width:auto;">
                        <br />
                        <button type="submit" class="btn btn-primary" style="width:150px;" @*onclick="OnPostCreateTract" *@> Save </button>

                        <form method="post" class="mt-3" enctype="multipart/form-data">
                            <div class="form-row">
                                <main>
                                    <EditForm Model="@leaseModel">

                                        <div class="container-fluid">

                                            <div class="card-body">

                                                <div class="form-row">
                                                    <label>Shut-In  </label>
                                                    <div class="col">
                                                        <InputNumber @bind-Value="@leaseModel.ShutInCosts" class="form-control" placeholder="0.00"></InputNumber>
                                                    </div>

                                                    <label>Broker</label>
                                                    <div class="col">
                                                        <InputNumber @bind-Value="@leaseModel.BrokerCosts" class="form-control" placeholder="0.00"></InputNumber>
                                                    </div>

                                                    <label>Damages   </label>
                                                    <div class="col">
                                                        <InputNumber @bind-Value="@leaseModel.Damages" class="form-control" placeholder="0.00"></InputNumber>
                                                    </div>
                                                </div>

                                                <div class="form-row">
                                                    <label>Advanced  </label>
                                                    <div class="col">
                                                        <InputNumber @bind-Value="@leaseModel.AdvancedRoyalty" class="form-control" placeholder="0.00"></InputNumber>
                                                    </div>

                                                    <label>Production</label>
                                                    <div class="col">
                                                        <InputNumber @bind-Value="@leaseModel.ProductionRoyalty" class="form-control" placeholder="0.00"></InputNumber>
                                                    </div>

                                                    <label>Acquisition</label>
                                                    <div class="col">
                                                        <InputNumber @bind-Value="@leaseModel.BonusToExtend" class="form-control" placeholder="0.00"></InputNumber>
                                                    </div>
                                                </div>

                                            </div>

                                        </div>
                                    </EditForm>
                                </main>

                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


@code {
    #region CASCADE PARAMS

    #region CASCADING PARAMS
    //[Parameter] public string? LeaseID { get; set; } = string.Empty;
    #endregion CASCADING PARAMS

    #endregion CASCADE PARAMS



    [Parameter]
    public bool IsVisible { get; set; }

    [Parameter]
    public EventCallback<bool> IsVisibleChanged { get; set; }

    [Parameter]
    public string? HeaderText { get; set; }

    [Parameter]
    public string? BodyText { get; set; }

    public void Show(string bodyText, string headerText = "")
    {
        HeaderText = headerText;
        BodyText = bodyText;
        IsVisible = true;
        StateHasChanged();
    }

    private void Close()
    {
        HeaderText = string.Empty;
        BodyText = string.Empty;
        IsVisible = false;
        StateHasChanged();
    }
}