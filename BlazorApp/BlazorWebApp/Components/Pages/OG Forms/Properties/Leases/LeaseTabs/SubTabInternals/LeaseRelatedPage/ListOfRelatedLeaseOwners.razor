    protected override async Task OnInitializedAsync()
    {
        // _leasePopulateDataGrids.TractMineralOwners = await _leasePopulateDataGrids
        //     .RetrieveRelatedTractMineralOwners(LeaseID);
        if (!string.IsNullOrEmpty(LeaseTablePK)) { }
        try
        {
            #region HTTP CALL
            var request = new HttpRequestMessage(HttpMethod.Get,
            _config["WebAPI"] + $"TractOwnership/SearchAllTractOwnershipByLeaseId/{IdFromListView}");
            var client = _clientFactory.CreateClient();
            var response = await client.SendAsync(request);
            #endregion HTTP CALL

            #region HTTP RESPONSE
            if (response.IsSuccessStatusCode)
            {
                using var responseStream = await response.Content.ReadAsStreamAsync();
                associatedTractOwnersViaTractId = await JsonSerializer.DeserializeAsync<List<TractOwnership>>(responseStream);
                //errorString = null;
            }
            else { _ = $"There was an error getting Tracts from DB: {response.ReasonPhrase}"; }
            #endregion HTTP RESPONSE
        }
        catch { }

    }

