<EditForm Model="@_tractOwnership">
    <div class="form-row align-items-center m-3">
        MINERAL OWNERS
    </div>
    <div class="form-row m-1">
        <InputText id="OwnerSearchTextbox"
                   @bind-Value="_tractOwnership.OwnerId"
                   style="width:auto; max-width:160px;"
                   class="m-1"
                   placeholder="Search">
        </InputText>
        <a class="btn btn-primary m-1" @onclick="RedirectPage">NEW</a>

        <AddUpdateMineralOwnerComponent LeaseID="@IdFromListView" @ref="popupRef" />
        <div class="form-row m-1">
        <div class="container border border-top border-bottom border-dark position-relative"
        style="overflow:scroll;
                        -webkit-overflow-scrolling:auto;
                        justify-content:left;
                        border-width:medium;
                        width:-webkit-fit-content;
                        height:175px;">
            <ol>
                @foreach (var _Ownership in associatedTractOwnersViaTractId)
                {
                    <li>
                        <div class="list-group" role="listbox">
                            <div class="row m-1" style="align-content:normal" role="listitem">
                                <label class="opacity-50 form-control-sm mb-0">Owner: @_Ownership.OwnerId</label>
                                <a class="form-control-sm" href="@($"/tractOwnership/{Convert.ToString(@_Ownership.Id)}/{@_Ownership.OwnerId}/{@_Ownership.TractId}/{@_Ownership.FormationType}")">@_Ownership.FormationType</a>
                                @* <span class="badge badge-primary badge-pill">@_tractOwnership.OwnerId</span> *@
                            </div>
                        </div>
                    </li>
                }
            </ol>
        </div>

    </div>
    </div>
</EditForm>

