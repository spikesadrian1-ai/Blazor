@page "/ListOfProperties"

@using ApplicationLayer.Entities.Property
@inject IHttpClientFactory _clientFactory
@inject Microsoft.Extensions.Configuration.IConfiguration _config

<br />
<div class="row" align="center">
    <div align="center">
        <h3>Available Properties</h3>
    </div>
</div>
<br />
<div>
    <GenDatabaseList Elements="getList">

        <TableHeader>
            <th>Grantor</th>
            <th>Grantee</th>
            <th>Filing Date</th>
            <th>Chain of Title</th>
            <th>Book</th>
            <th>Page</th>
            @* <th>Volume</th> *@
        </TableHeader>

        <RowTemplate Context="propertys">
            <td><a href="@($"/contracts/{Convert.ToString(propertys.Id)}/{propertys.PropertyId}")" class="nav-link">@propertys.PropertyId</a></td>
            <td>@propertys.Description</td>
            <td>@propertys.PropertyType</td>
            <td>@propertys.SpecialProvisionsNotes</td>
            <td>@propertys.Status</td>
            @* <td>@propertys.Responsible</td> *@
            @* <td>@propertys.Volume</td> *@
        </RowTemplate>
        <HrefEditModal>
            <a href="@($"#edit{title}")" class="edit" data-toogle="modal">
                <i class="material-icons" data-toogle="tooltip" title="Edit">&#xE254;</i>
            </a>
        </HrefEditModal>
        <HrefDeleteModal>
            <a href="@($"#delete{title}")" class="delete" data-toogle="modal">
                <i class="material-icons" data-toogle="tooltip" title="Delete">&#xE872;</i>
            </a>
        </HrefDeleteModal>
    </GenDatabaseList>
</div>



@code {

    static string title = "CreateOrUpdateTractMainForm";

    string errorString;

    protected override async Task OnInitializedAsync()
    {
        //await PopulateTracts();

        //// ADDED TO IMPLEMENT LOADING INDICATOR
        await Task.Run(() => PopulateList());
    }

    #region RETRIEVE LIST

    List<PropertyMainForm> getList { get; set; } = new List<PropertyMainForm>();

    async Task<List<PropertyMainForm>> PopulateList(int page = 1, int quantityPerPage = 10)
    {
        var request = new HttpRequestMessage(HttpMethod.Get,
        _config["API_URL"] + "PropertyMain");
        var client = _clientFactory.CreateClient();
        var response = await client.SendAsync(request);

        if (response.IsSuccessStatusCode)
        {
            // PART OF THE LOADING INDICATOR
            System.Threading.Thread.Sleep(0);

            //totalPageQuantity = int.Parse(response.Headers.GetValues("pagesQuantity").FirstOrDefault());

            using var responseStream = await response.Content.ReadAsStreamAsync();
            getList = await JsonSerializer.DeserializeAsync<List<PropertyMainForm>>(responseStream);

            errorString = null;

        }
        else
        {
            errorString = $"There was an error getting Tracts: {response.ReasonPhrase}";
        }

        return getList;
    }

    #endregion RETRIEVE LIST OF TRACTS
}

