@page "/ListOfTractsComponent"

@using ApplicationLayer.Entities
@using DomainLayer.Entities.Assets.Tracts

@inject IJSRuntime jsRuntime
@inject IHttpClientFactory _clientFactory
@inject Microsoft.Extensions.Configuration.IConfiguration _config

<TractMoreBackButton></TractMoreBackButton>

<br />
<div class="row" align="center">
    <div align="center">
        <h3>Available Tracts</h3>
    </div>
</div>
<br />
<br />
<div>
    <GenDatabaseList Elements="getTracts">

        <TableHeader>
            <th>Tract ID</th>
            <th>Name</th>
            <th>Total Acres</th>
            <th>Developed Acres</th>
            <th>Description</th>
            <th>Status</th>
            <th>Provisions</th>
        </TableHeader>

        <RowTemplate Context="Tracts">
            <td><a href="@($"/Tracts/{Convert.ToString(Tracts.Id)}/{Tracts.TractId}")" class="nav-link">@Tracts.TractId</a></td>
            <td>@Tracts.TractNameShort</td>
            <td>@Tracts.TotalAcreage</td>
            <td>@Tracts.Developed</td>
            <td>@Tracts.ShortDescription</td>
            <td>@Tracts.TractStatus</td>
            <td>@Tracts.SpecialProvisionsNotes</td>
        </RowTemplate>
        <HrefEditModal>
            <a href="@($"#edit{title}")" class="edit" data-toogle="modal">
                <i class="material-icons" data-toogle="tooltip" title="Edit">&#xE254;</i>
            </a>
        </HrefEditModal>
        <HrefDeleteModal>
            <a href="@($"#delete{title}")" class="delete" data-toogle="modal">
                <i class="material-icons" data-toogle="tooltip" title="Delete">&#xE872;</i>
            </a>
        </HrefDeleteModal>
    </GenDatabaseList>
</div>


@code
{
    public TractMainForm Tracts { get; set; } = new TractMainForm();
    static string title = "CreateOrUpdateTractMainForm";

    string errorString;

    protected override async Task OnInitializedAsync()
    {
        //await PopulateTracts();

        //// ADDED TO IMPLEMENT LOADING INDICATOR
        await Task.Run(() =>PopulateTracts());
    }

    #region PAGINATION

    private int totalPageQuantity;
    private int currentPage = 1;
    private async Task SelectedPage(int page)
    {
        currentPage = page;
        await PopulateTracts(page);
    }

    #endregion PAGINATION

    #region RETRIEVE LIST OF TRACTS

    List<TractMainForm> getTracts { get; set; } = new List<TractMainForm>();

    async Task<List<TractMainForm>> PopulateTracts(int page = 1, int quantityPerPage = 10)
    {
        var request = new HttpRequestMessage(HttpMethod.Get,
        _config["API_URL"] + "TractMainForms");
        var client = _clientFactory.CreateClient();
        var response = await client.SendAsync(request);

        if (response.IsSuccessStatusCode)
        {
            // PART OF THE LOADING INDICATOR
            System.Threading.Thread.Sleep(0);

            //totalPageQuantity = int.Parse(response.Headers.GetValues("pagesQuantity").FirstOrDefault());

            using var responseStream = await response.Content.ReadAsStreamAsync();
            getTracts = await JsonSerializer.DeserializeAsync<List<TractMainForm>>(responseStream);

            errorString = null;

        }
        else
        {
            errorString = $"There was an error getting Tracts: {response.ReasonPhrase}";
        }

        return getTracts;
    }

    #endregion RETRIEVE LIST OF TRACTS

}