    LeaseRelatedPageServices _leaseRelatedPageServices;

    /* public */
    List<Burdens> associatedTractBurdensViaTractId { get; set; }
        = new List<Burdens>();

    List<Burdens> ListAllBurdensViaLeaseId { get; set; }
        = new List<Burdens>();

    string errorString;

    // if  (!string.IsNullOrEmpty(TractId))
