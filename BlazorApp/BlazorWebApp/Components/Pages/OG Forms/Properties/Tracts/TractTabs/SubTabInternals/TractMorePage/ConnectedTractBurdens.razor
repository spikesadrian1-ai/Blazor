    protected override async Task OnInitializedAsync()
    {

        if (!string.IsNullOrEmpty(TractId)) //&& (string.IsNullOrEmpty(LeaseID)))
        {
            fromTractFormState = true;

            var request = new HttpRequestMessage(HttpMethod.Get,
            _config["API_URL"] + $"Burdens/SearchAllBurdensByTractId/{TractId}");/*tractOwnership.*/
            var client = _clientFactory.CreateClient();
            HttpResponseMessage response = await client.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                using var responseStream = await response.Content.ReadAsStreamAsync();
                associatedTractBurdensViaTractId = await JsonSerializer
                             .DeserializeAsync<List<Burdens>>(responseStream);

                errorString = null;
            }
            else
            {
                errorString = $"There was an error getting Burdens Data: {response.ReasonPhrase}";
            }
        }
        else if (!string.IsNullOrEmpty(LeaseID))    //((!string.IsNullOrEmpty(LeaseID)) && (string.IsNullOrEmpty(TractId)))
        {
            fromLeaseFormState = true;

            var request = new HttpRequestMessage(HttpMethod.Get,
            _config["API_URL"] + $"Burdens/SearchAllBurdensByLeaseId/{LeaseID}");/*tractOwnership.*/
            var client = _clientFactory.CreateClient();
            HttpResponseMessage response = await client.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                using var responseStream = await response.Content.ReadAsStreamAsync();
                associatedTractBurdensViaTractId = await JsonSerializer
                             .DeserializeAsync<List<Burdens>>(responseStream);

                errorString = null;
            }
            else
            {
                errorString = $"There was an error getting Burdens Data: {response.ReasonPhrase}";
            }
        }


