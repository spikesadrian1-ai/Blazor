@page "/ConnectedTractROWs"

@inject IJSRuntime jsRuntime
@inject Microsoft.Extensions.Configuration.IConfiguration _config
@inject IHttpClientFactory _clientFactory

@inherits TractMainPageBase

<TractMoreBackButton></TractMoreBackButton>

<TractMoreSubMenu></TractMoreSubMenu>

@{
    bool UserSelectedNewTract = true;
    bool UserSelectedViewTractsList = false;

    async Task UserCreatesNewTract()
    {
        UserSelectedViewTractsList = false;
        UserSelectedNewTract = true;
    }

    async Task UserViewsExistingTracts()
    {
        UserSelectedNewTract = false;
        UserSelectedViewTractsList = true;
    }

}

@* TODO: turn into switch statement *@
