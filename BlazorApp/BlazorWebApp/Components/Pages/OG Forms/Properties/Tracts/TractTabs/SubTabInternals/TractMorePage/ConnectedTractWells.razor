    #endregion CASCADING PARAMS

    // static string LeaseId
    // {
    //     get => LeaseId;
    //     set => value.ToString();
    // }

    string ComponentName = "Well(s)";

    public TractOwnership OwnerSearch { get; set; } =
    new TractOwnership(); //= null;

    // [Inject]
    // private  LeaseRelatedPageServices _leaseRelatedPageServices { get; set; }

    private async Task OnCountySelected()
    {

        // CALL SERVICES METHOD W/PARAMS WITH STATE INFO
        // CLEAR STATE SELECTION IF NEEDED
        // RESET ANY PARAMS TO AVOID UNEXPECTED ERRORS
    }

    private async Task OnStateSelected()
    {

