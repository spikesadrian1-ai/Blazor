<EditForm Model="@OwnerSearch">
    <div class="form-row align-content-center m-3">
        WELLS
    </div>
    <div class="row m-1">
        <a class="btn btn-primary m-1" @onclick="QuickAddFullAcreagesRedirectPage">FULL</a>
        <QuickAddFullAcreagesComponent TractID="@TractID" @ref="popupQuickAddFullAcreagesRef" />

        <a class="btn btn-primary m-1" @onclick="QuickAddNoAcreagesRedirectPage">Quick</a>
        <QuickAddNoAcreagesComponent TractID="@TractID" @ref="popupQuickAddNoAcreagesRef" />

        <a class="btn btn-primary m-1" @onclick="NewWellRedirectPage">PARTIAL</a>
        <NewWellComponent TractID="@TractID" @ref="popupNewWellRef" />

        <div class="row m-1">
            <div class="container border border-top border-bottom border-dark position-relative"
                 style="overflow:scroll;
                        -webkit-overflow-scrolling:auto;
                        justify-content:left;
                        border-width:medium;
                        width:-webkit-fit-content;
                        height:175px;">
                <ol>
                    @foreach (var item in TractWells)
                    {
                        <li>
                            <div class="list-group" role="listbox">
                                <div class="row m-1" style="align-content:normal" role="listitem">
                                    <h8>Well ID:  </h8>
                                    @* <td> *@
                                    <a href="@($"/Well/{item.WellId}")" class="nav-link">@item.WellId</a>
                                    @* </td> *@
                                    @* <a href="@($"/ListOfTractsComponent/{@item.WellId}")">@item.WellId</a> *@
                                    @* <span class="badge badge-primary badge-pill">@item.WellId</span> *@
                                </div>
                            </div>
                        </li>
                    }
                </ol>
            </div>
        </div>
    </div>
</EditForm>

@code
{
    static string title = "WellTractsModal";

    #region CASCADING PARAMS
