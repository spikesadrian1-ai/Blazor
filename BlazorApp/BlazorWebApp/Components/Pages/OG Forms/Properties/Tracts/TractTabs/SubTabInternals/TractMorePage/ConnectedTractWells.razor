    }


    // private int totalPageQuantity;
    // private int currentPage = 1;

    List<DomainLayer.Entities.Assets.Wells.WellTractsConnection> TractWells { get; set; }
        = new List<DomainLayer.Entities.Assets.Wells.WellTractsConnection>();

    List<ApplicationLayer.Entities.WellTractsConnection> ListOfWellsViaLeaseId { get; set; }
        = new List<ApplicationLayer.Entities.WellTractsConnection>();

    string errorString;

    protected override async Task OnInitializedAsync()
    {
        if (TractID != string.Empty)
        {
            var request = new HttpRequestMessage(HttpMethod.Get,
            _config["API_URL"] + $"WellTract/SearchAllTractWellsByTractId/{TractID}");
            var client = _clientFactory.CreateClient();
            HttpResponseMessage response = await client.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                using var responseStream = await response.Content.ReadAsStreamAsync();
                TractWells = await JsonSerializer.DeserializeAsync<List<DomainLayer.Entities.Assets.Wells.WellTractsConnection>>(responseStream);

                errorString = null;
            }
            else
            {
                errorString = $"There was an error getting Prospects Data: {response.ReasonPhrase}";
            }
        }

        if (LeaseID != string.Empty)
        {
            ListOfWellsViaLeaseId = await _leasePopulateDataGrids
            .RetrieveAllRelatedWellsByLeaseIdAsync(LeaseID);
        }

    }

    private QuickAddFullAcreagesComponent popupQuickAddFullAcreagesRef;

    private void QuickAddFullAcreagesRedirectPage()
    {
        // Shows the popup at the center of the screen
        popupQuickAddFullAcreagesRef.QuickAddFullAcreagesComponentShow("Popup body text");
    }

    private QuickAddNoAcreagesComponent popupQuickAddNoAcreagesRef;

    private void QuickAddNoAcreagesRedirectPage()
    {
        // Shows the popup at the center of the screen
        popupQuickAddNoAcreagesRef.QuickAddNoAcreagesComponentShow("Popup body text");
    }

    private NewWellComponent popupNewWellRef;

    private void NewWellRedirectPage()
    {
        // Shows the popup at the center of the screen
        popupNewWellRef.NewWellRefShow("Popup body text");
    }
}

