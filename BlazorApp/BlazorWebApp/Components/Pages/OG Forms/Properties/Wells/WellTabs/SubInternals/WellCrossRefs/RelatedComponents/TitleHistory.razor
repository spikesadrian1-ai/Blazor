                                        </BlazorWebApp.Pages.OG_Forms.Properties.Wells.WellTabs.SubInternals.WellCrossRefs.RelatedComponents.PaymentHistorySubControls.HistoricalPayments> *@
                                //<RelatedContracts @onreadystatechan-9ge="()=>ShowRelatedContracts()" @ref="popupRefContracts" />

                                <RelatedPayments />
                            }
                            @if (showRelatedDrafts == true)
                            {
                                <RelatedDrafts WellId="@WellId" />
                                //<RelatedLeases @ref="popupRefLeases" />
                            }
                            @if (showRelatedHistory == true)
                            {
                                <RelatedHistorys />
                            }

                        </div>
                    </div>
                    @* </div> *@
                </div>
                @* <div class="container-fluid border border-top border-bottom m-1"
                     style="width:inherit; height:;"> 
                </div> *@
            </div>
        </div>
