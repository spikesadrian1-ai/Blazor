</div>

@code {
    //
    // [Parameter] public string WellId { get; set; } = string.Empty;

    bool showHistoricalPayments;
    bool showRelatedDrafts = false;
    bool showRelatedHistory = false;


    // async Task ShowRelatedPayments()
    // {
    //     if ((showRelatedDrafts = true) || (showRelatedHistory = true))
    //     {
    //         showRelatedDrafts = false;
    //         showRelatedHistory = false;
    //     }

    //     /* return */
    //     showPayments = true;
    // }

    private void ShowRelatedPayments()
    {
        // if ((showRelatedDrafts == true) || (showRelatedHistory == true))
        // {
        //     showRelatedDrafts = false;
        //     showRelatedHistory = false;
        // }

        // showHistoricalPayments = true;

        if (showHistoricalPayments == false)
        {
            showRelatedDrafts = false;
            showRelatedHistory = false;

            //StateHasChanged();
        }

        showHistoricalPayments = true;

        // Shows the popup at the center of the screen
        //popupRefContracts.Show("Popup body text");
    }

    async Task ShowRelatedDrafts()
    {
        if ((showHistoricalPayments = true) || (showRelatedHistory = true))
        {
            showHistoricalPayments = false;
            showRelatedHistory = false;
        }

        /* return */
        showRelatedDrafts = true;
    }

    async Task ShowRelatedHistory()
    {
        if ((showHistoricalPayments = true) || (showRelatedHistory = true))
        {
            showHistoricalPayments = false;
            showRelatedDrafts = false;
        }

        /* return */
        showRelatedHistory = true;
    }

    [Parameter]
    public bool IsVisible { get; set; }

    [Parameter]
    public EventCallback<bool> IsVisibleChanged { get; set; } = new EventCallback<bool>();

    [Parameter]
    public string? HeaderText { get; set; }

    [Parameter]
    public string? BodyText { get; set; }

    // [Parameter]
    // public IHandleAfterRender handleAfterRender { get; set; }

    public void Show(string bodyText, string headerText = "")
    {
        HeaderText = headerText;
        BodyText = bodyText;
        IsVisible = true;
        //handleAfterRender.OnAfterRenderAsync();
        StateHasChanged();

    }

    private void Close()
    {
        HeaderText = string.Empty;
        BodyText = string.Empty;
        IsVisible = false;
        StateHasChanged();
    }

    void OnAfterRenderAsync()
    {
        StateHasChanged();
    }
}
