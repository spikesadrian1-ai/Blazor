@inherits WellMainBase

<div class="container-fluid m-1 auto"
     style="width:inherit; height:;">
    <div class="card accent-card">
        <div class="card-body" style="width:inherit; height:;">
            <div class="card-header form-control-lg">
                <strong class="me-auto">Title History</strong>
            </div>
            <br />
            @* <button type="submit" class="btn btn-primary" style="width:150px;" @onclick="(() => SaveNewLeaseAsync(leaseModel))"> Payments </button>
            <button type="submit" class="btn btn-danger" style="width:150px;">Drafts</button>
