    public async Task<ICollection<string>> RetrieveListOFAssociates()
    {
        try
        {
            #region HTTP CALL
            var request = new HttpRequestMessage(HttpMethod.Get,
            _config["API_URL"] + "owneraddressesmain/GetListOfAssociateNames");
            var client = _clientFactory.CreateClient();
            var response = await client.SendAsync(request);
            #endregion HTTP CALL

            #region HTTP RESPONSE
            if (response.IsSuccessStatusCode)
            {
                using var responseStream = await response.Content.ReadAsStreamAsync();
                associateLists = await JsonSerializer.DeserializeAsync<List<string>>(responseStream);
                //ErrorString = null;
            }
            else
            {
                //ErrorString = $"There was an error getting Counties: {response.ReasonPhrase}";
            }
            #endregion HTTP RESPONSE
