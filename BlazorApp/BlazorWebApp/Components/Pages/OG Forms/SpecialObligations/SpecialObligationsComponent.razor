@page "/SpecialObligations"
@page "/SpecialObligations/{ObligationType}/{TractID}"

@using ApplicationLayer.Entities.SpecialObligation

@inject IJSRuntime jsRuntime
@inject Microsoft.Extensions.Configuration.IConfiguration _config
@inject IHttpClientFactory _clientFactory

@inherits LeaseMainBase

@{
    #region POPUP

    var showClass = IsVisible ? "d-block" : "d-none";

    #endregion POPUP

    #region ENTITY

    SpecialObligations specialObligationEntity = new SpecialObligations();

    #endregion ENTITY

    #region TRACT FORM STATE

    /// TRACT RELATED FORM: NEW BUTTON PRESSED
    if (ObligationTypes is null)
    {
        /// CHECK STATE: NO LEASE(S) ATTACHED TO CURRENT TRACT
        if ((leaseModel.LeaseId is null) && (!string.IsNullOrEmpty(TractID)))
        {
            specialObligationEntity.LeaseId = Convert.ToString(AttachedLeaseIDs);
        }

        /// CHECK STATE: ATTACHED LEASE(S) AND TRACT
        if ((leaseModel.LeaseId != string.Empty) && (!string.IsNullOrEmpty(TractID)))
        {
            specialObligationEntity.LeaseId = leaseModel.LeaseId;

        }

        // DEFAULT VAULES
        specialObligationEntity.TractId = TractID;
        specialObligationEntity.ObligationType = "Test Type";    //Convert.ToString(ListOfObligationTypes);
        specialObligationEntity.ObligationDate = null;
        specialObligationEntity.ObligationAmount = Convert.ToDecimal(0.00);
        specialObligationEntity.ResponsiblePartyId = string.Empty;  // TODO: IF MORE THAN ONE PERSON THEN MAKE A LIST
        specialObligationEntity.DescriptionOfObligation = string.Empty;
        specialObligationEntity.RecurringObligation = string.Empty; //TODO:
        specialObligationEntity.FormationId = string.Empty;
        specialObligationEntity.Recommendation = string.Empty;
        specialObligationEntity.RecurringPeriod = 0;
        specialObligationEntity.ExpirationDate = null;

    }

    /// TRACT RELATED FORM: LISTVIEW BUTTON PRESSED
    if (!string.IsNullOrEmpty(ObligationTypes))
    {
        /// CHECK STATE: NO LEASE(S) ATTACHED
        if (leaseModel.LeaseId == string.Empty) { specialObligationEntity.LeaseId = Convert.ToString(AttachedLeaseIDs); }

        /// CHECK STATE: ATTACHED LEASE
        if (leaseModel.LeaseId != string.Empty) { specialObligationEntity.LeaseId = leaseModel.LeaseId; }
    }

    #endregion TRACT FORM STATE
}

