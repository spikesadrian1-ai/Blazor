<EditForm Model="@ownership">
    <div class="modal p-3 @showClass" data-bs-autohide="true" data-bs-delay="5000" style="align-self:center; ">

        <div class="container position-relative"
             style="overflow:auto;
                justify-content:left;
                border-width:medium;
                width:-webkit-fit-content;
                height:auto;">

            <div class="modal-body" style=" width:auto; height:auto;">

                <div class="modal-content align-content-center" style="width:700px; height:-webkit-fit-content;">

                    <div class="modal-header">
                        <button type="button" class="btn-close" aria-label="Close" @onclick="Close"></button>
                    </div>

                    <div class="card" style=" width:700px; height:max-content;">

                        <div class="card-header">
                            <strong class="me-auto">New Mineral Ownership for @($"{LeaseModel.LeaseId}")</strong>
                        </div>
                        <div class="card-body m-auto" style="width:auto;">

                            <button type="submit" class="btn btn-primary" style="width:150px;" @*onclick="OnPostCreateTract" *@> Save </button>

                            <div class="col">

                                <div class="card accent-card " style="width:max-content;">

                                    <div class="card-body">

                                        <div class=form-row>
                                            <div class="col-4">
                                                @* <label>TRACT ID</label> *@
                                                <select asp-for="State_ID" asp-items="Html.GetEnumSelectList<States>()">
                                                    @* role="presentation" *@
                                                    <option value="">Tract ID</option>
                                                    @* @Html.ValidationMessage("state") *@
                                                </select>
                                            </div>

                                            <div class="col-3">
                                                @* <label>TRACT TYPE</label> *@
                                                <select asp-for="State_ID" asp-items="Html.GetEnumSelectList<States>()">
                                                    @* role="presentation" *@
                                                    <option value="">Tract Type</option>
                                                    @* @Html.ValidationMessage("state") *@
                                                </select>
                                            </div>

                                            <div class="col-4">
                                                @* <label>FORMATION TYPE</label> *@
                                                <select asp-for="State_ID" asp-items="Html.GetEnumSelectList<States>()">
                                                    @* role="presentation" *@
                                                    <option value="">Formation Type</option>
                                                    @* @Html.ValidationMessage("state") *@
                                                </select>
                                            </div>
                                        </div>
                                        <br />
                                        <div class=form-row>
                                            <div class="col-8" style="width:auto; height:auto;">
                                                @* <label>Description Of Obligation</label> *@
                                                <InputTextArea @bind-Value="ownership.LegalDescription" placeholder="Short Description"></InputTextArea>
                                            </div>
                                            <div class="col-4">
                                                <button type="submit" class="btn btn-primary" style="width:150px;" @*onclick="OnPostCreateTract" *@> Add New Owners </button>
                                            </div>
                                        </div>

                                    </div>
                                    <div class="card-body">

                                        <div class="form-row">
                                            <div class="col-4">
                                                @* <label>Owner ID</label> *@
                                                <select asp-for="State_ID" asp-items="Html.GetEnumSelectList<States>()">
                                                    @* role="presentation" *@
                                                    <option value="">Owner ID</option>
                                                    @* @Html.ValidationMessage("state") *@
                                                </select>
                                            </div>
                                            <div class="col-4">
                                                <button type="submit" class="btn btn-primary" style="width:150px;" @*onclick="OnPostCreateTract" *@> Transfer Interests </button>
                                            </div>
                                            <div class="col-4">
                                                @* <label>Status of Lease</label> *@
                                                <select asp-for="State_ID" asp-items="Html.GetEnumSelectList<States>()">
                                                    @* role="presentation" *@
                                                    <option value="">Lease Status</option>
                                                    @* @Html.ValidationMessage("state") *@
                                                </select>
                                            </div>
                                        </div>
                                        <br />
                                        <div class="form-row">
                                            <div class="col-8" style="width:auto; height:auto;">
                                                @* <label>Description Of Obligation</label> *@
                                                <InputTextArea @bind-Value="ownership.Formula" placeholder="1/4 or 0.00000000"></InputTextArea>
                                            </div>
                                            <div class="col-4">
                                                @* <label>Status of Lease</label> *@
                                                <select asp-for="Lease_ID" class="form-control " asp-items="Html.GetEnumSelectList<States>()">
                                                    @* role="presentation" *@
                                                    <option value="">Lease ID</option>
                                                    @* @Html.ValidationMessage("state") *@
                                                </select>
                                            </div>
                                        </div>
                                        <br />
                                        <div class="form-row">

                                            <div class="col-5">

                                                <div class="form-row">

                                                    <div class="col-5">
                                                        Interest
                                                        <InputNumber style="width:100px;" @bind-Value="ownership.MineralInterest" placeholder="0.00000000"></InputNumber>
                                                        <br />
                                                    </div>
                                                </div>
                                                <div class="form-row">

                                                    <div class="col-5">
                                                        Surfac
                                                        <InputNumber style="width:100px;" @bind-Value="ownership.SurfaceInterest" placeholder="0.00000000"></InputNumber>
                                                        <br />
                                                    </div>

                                                </div>
                                                <div class="form-row">
                                                    @*  <div class="col">
                                                    Suspense <label>Suspense</label>
                                                </div> *@
                                                    <div class="col-5">
                                                        <InputSelect style="width:100px;" @bind-Value="ownership.SuspenseCode" placeholder="Suspense Code"></InputSelect>
                                                        <br />
                                                    </div>

                                                </div>
                                                <div class="form-row">
                                                    @* <div class="col">
                                                    Tenure <label>Tenure</label>
                                                </div> *@
                                                    <div class="col-5">
                                                        <InputSelect style="width:100px;" @bind-Value="ownership.TenureCode" placeholder="Tenure Code">Tenure Code</InputSelect>
                                                        <br />
                                                    </div>

                                                </div>

                                            </div>

                                            <div class="col-1"></div>

                                            <div class="col-6">

                                                <div class="card-header">
                                                    OWNER ACREAGE
                                                </div>
                                                <br />
                                                <div class="form-row">

                                                    @* Total
                                                <InputNumber style="width:100px;" @bind-Value="ownership.Total" placeholder="0.00000000"></InputNumber> *@
                                                    <div class="col">
                                                        Total @* <label>Producing</label> *@
                                                    </div>
                                                    <div class="col">
                                                        <InputNumber style="width:100px;" @bind-Value="ownership.Total" placeholder="0.00000000"></InputNumber>
                                                        <br />
                                                    </div>
                                                </div>
                                                <div class="form-row">
                                                    <div class="col">
                                                        Producing @* <label>Producing</label> *@
                                                    </div>
                                                    <div class="col">
                                                        <InputNumber style="width:100px;" @bind-Value="ownership.Producing" placeholder="0.00000000"></InputNumber>
                                                        <br />
                                                    </div>

                                                </div>
                                                <div class="form-row">
                                                    <div class="col">
                                                        Non-Producing @* <label>Non-Producing</label> *@
                                                    </div>
                                                    <div class="col">
                                                        <InputNumber style="width:100px;" @bind-Value="ownership.NonProducing" placeholder="0.00000000"></InputNumber>
                                                        <br />
                                                    </div>

                                                </div>
                                                <div class="form-row">
                                                    <div class="col">
                                                        Other @* <label>Other</label> *@
                                                    </div>
                                                    <div class="col">
                                                        <InputNumber style="width:100px;" @bind-Value="ownership.Other" placeholder="0.00000000"></InputNumber>
                                                        <br />
                                                    </div>

                                                </div>
                                                <div class="form-row">
                                                    <div class="col">
                                                        Outside @* <label>Outside</label> *@
                                                    </div>
                                                    <div class="col">
                                                        <InputNumber style="width:100px;" @bind-Value="ownership.Outside" placeholder="0.00000000"></InputNumber>
                                                        <br />
                                                    </div>

                                                </div>

                                            </div>

                                        </div>
                                    </div>
                                </div>
                                <br />
                                <div class="form-row">
                                    <div class="col ">
                                        @* <InputText @bind-Value="EntityId" placeholder="Entity"></InputText> *@
                                    </div>
                                    <div class="col ">
                                        @* <InputText @bind-Value="TractID" placeholder="TractId"></InputText> *@
                                    </div>
                                    <div class="col ">
                                        <InputText @bind-Value="LeaseID" placeholder="LeaseId"></InputText>
                                    </div>
                                    <div class="col ">
                                        <InputText @bind-Value="EasementId" placeholder="EasementId"></InputText>
                                    </div>
                                    <div class="col ">
                                        <InputText @bind-Value="SuaId" placeholder="SuaId"></InputText>
                                    </div>
                                    <div class="col ">
                                        <InputText @bind-Value="RowId" placeholder="RowId"></InputText>
                                    </div>
                                </div>

                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</EditForm>


