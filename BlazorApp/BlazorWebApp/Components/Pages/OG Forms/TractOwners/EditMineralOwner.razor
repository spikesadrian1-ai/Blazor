                                    @if (InitialState == true)
                                    {
                                       @*  <select id="ListAllCounties" class="form-control" style="align-self:center; width:200px;">
                                            <option value="0">Select County</option>
                                            @foreach (var item in ListAllCounties)
                                            {
                                                <option value="@item.Id">@item.CountyName</option>
                                            }
                                        </select> *@
                                    }
                                    else
                                    if (InitialState == false)
                                    {
                                        <InputNumber @bind-Value="@ownership.Producing" class="form-control-sm text-sm-right" style="align-self:center; width:200px;" placeholder="(Ex. Payout)"></InputNumber>
                                    }
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="col-3">
                                    <label class="opacity-50 form-control-sm mb-0">Non-Producing</label>
                                </div>
                                <div class="col" style="padding-bottom:3px;">
                                    @if (InitialState == true)
                                    {
                                        @* <select id="ListAllCounties" class="form-control" style="align-self:center; width:200px;">
                                            <option value="0">Select County</option>
                                            @foreach (var item in ListAllCounties)
                                            {
                                                <option value="@item.Id">@item.CountyName</option>
                                            }
                                        </select> *@
