                                    {
                                        <InputNumber @bind-Value="@ownership.NonProducing" class="form-control-sm text-sm-right" style="align-self:center; width:200px;" placeholder="(Ex. Payout)"></InputNumber>
                                    }
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="col-3">
                                    <label class="opacity-50 form-control-sm mb-0">Other</label>
                                </div>
                                <div class="col" style="padding-bottom:3px;">
                                    @if (InitialState == true)
                                    {
