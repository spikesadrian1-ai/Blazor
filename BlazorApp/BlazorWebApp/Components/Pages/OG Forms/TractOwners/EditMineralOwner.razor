                                        <InputTextArea @bind-Value="@ownership.Formula" class="form-control-sm text-sm-right" style="align-self:center; width:auto; height:60px;" placeholder="(Ex. 1/4 or .25000000)"></InputTextArea>
                                    }
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="col-3">
