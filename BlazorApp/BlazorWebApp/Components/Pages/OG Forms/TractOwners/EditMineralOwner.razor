@page "/tractOwnership/{ID}/{OwnerID}/{TractID}/{Formations}"

@inherits TractOwnerBase

@{
    ownership.Id = int.Parse(ID);
}

<button type="submit" class="btn btn-primary" style="width:150px;" @onclick="(() => SaveButton(ownership))"> Save </button>
<button type="submit" class="btn btn-danger" style="width:150px;" @onclick="DeleteButton">Delete</button>
<button type="button" class="btn btn-primary" style="width:150px;" @*onclick="OnPostCreateTract" *@>Print</button>

<EditForm Model="@ownership">
    <div class="container border border-top border-bottom m-1 auto">
        <div class="card accent-card">
            <form method="post" class="mt-3" enctype="multipart/form-data">
                <div class="card-body">
                    <div class="card-header form-control-sm">
                        @{
                            if (InitialState == false)
                            {
                                <strong class="me-auto">Mineral @($"{OwnerID}") for Tract ID: @($"{TractID}")</strong>
                            }
                            else
                            if (InitialState == true)
                            {
                                <strong class="me-auto">New Tract Information Form</strong>
                            }
                        }
                    </div>
                </div>
                <div class="form-row">
                    <div class="col" style="align-items:center; align-content:center;">
                        <div class="card accent-card mb-3">
                            <div class="card-header form-control">Identification</div>
                            <div class="card-body">
                                <div class=form-row>
                                    <div class="col">
                                        <label>Tract</label>
                                        @if (InitialState == false)
                                        {
                                            <InputText @bind-Value="TractID" class="form-control-sm" style="width:200px;"></InputText>
                                        }
                                        else
                                        if (InitialState == true)
                                        {
                                            <select class="form-control" data-bind=" " style="width:200px;">
                                                <option value="">Tract ID</option>
                                            </select>
                                        }
                                    </div>

                                    <div class="col">
                                        <label>Type</label>
                                        @if (InitialState == false)
                                        {
                                            <InputText @bind-Value="ownership.TractType" class="form-control-sm" style="width:200px;"></InputText>
                                        }
                                        else
                                        if (InitialState == true)
                                        {
                                            <select class="form-control" data-bind=" " style="width:200px;">
                                                <option value="">Tract Type</option>
                                            </select>
                                        }
                                    </div>

                                    <div class="col">
                                        <label>Form</label>
                                        @if (InitialState == false)
                                        {
                                            @* if (Convert.ToInt16(Formations) == 1)
                                                {

                                                }
                                                else
                                                if (Convert.ToInt16(Formations) = 1)
                                                {

                                                } *@
                                            <InputText @bind-Value="Formations" class="form-control-sm" style="width:200px;"></InputText>
                                        }
                                        else
                                        if (InitialState == true)
                                        {
                                            <select class="form-control" data-bind=" " style="width:200px;">
                                                <option value="">Formation Type</option>
                                            </select>
                                        }

                                    </div>

                                    <div class="col">
                                        <button type="submit" class="btn btn-primary form-control-sm" style="width:175px;" @*onclick="OnPostCreateTract" *@> Formation Change </button>
                                    </div>
                                </div>
                                <div class=form-row>
                                    <label>Description</label>
                                    <div class="col">
                                        @if (InitialState == false)
                                        {
                                            <InputTextArea @bind-Value="ownership.LegalDescription" class="form-control-sm" style="width:350px; height:60px; overscroll-behavior-x:auto; padding-bottom:3px;" placeholder=""></InputTextArea>
                                        }
                                        else
                                        if (InitialState == true)
                                        {

                                        }

                                    </div>
                                    <br />
                                    <div class="col">
                                        <button type="submit" class="btn btn-primary form-control-sm text-wrap" style="width:200px; padding-bottom:3px; " @*onclick="OnPostCreateTract" *@> Add New Owner to New Formation </button>
                                    </div>
                                </div>

                                <div class="form-row">
                                    
                                    <label>Owner</label>
                                    <div class="col" style="padding-bottom:3px;">
                                        @if (InitialState == true)
                                        {
                                            @* <select id="ListOfTractStatuses" class="form-control-sm" style=" width:275px;">
                                                <option value="0">Select Owner</option>
                                                @foreach (var item in ListOfTractStatuses.Where(x => x.Length > 1))
                                                {
                                                    <option value="@item.">@item.</option>
                                                }
                                            </select> *@
                                        }
                                        else
                                        if (InitialState == false)
                                        {

                                            <InputText @bind-Value="@OwnerID" class="form-control-sm text-sm-right" style="align-self:center; width:300px; overflow:auto;" placeholder="(Ex. Payout)"></InputText>
                                            @* @foreach (var item in ListOfTractStatuses.Where(x => x.Length > 1))
                                            {
                                                TractModel.TractStatus = ListOfTractStatuses.Where(x => x.Contains(TractModel.TractStatus)).ToString();
                                                <option value="@item.">@item.</option>
                                            } *@
                                        }
                                    </div>
                                    
                                    <div class="col" style="padding-bottom:3px;">
                                        <button type="submit" class="btn btn-primary form-control-sm" style="width:200px;" @*onclick="OnPostCreateTract" *@> Transfer Interests </button>
                                        @if (InitialState == true)
                                        { }
                                        else
                                        if (InitialState == false)
                                        {

                                        }
                                    </div>

                                    <div class="col">
                                        <label>Lease Status</label>
                                        @if (InitialState == true)
                                        {
                                            <InputSelect @bind-Value="ownership.StatusOfLease" class="form-control-sm" style="width:175px;"></InputSelect>
                                        }
                                        else
                                        if (InitialState == false)
                                        {
                                            <InputText @bind-Value="ownership.StatusOfLease" class="form-control-sm" style="width:175px;"></InputText>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="form-row">
                    <div class="col-6">
                        <div class="card-header form-control">Ownership Interests</div>
                        <div class="card-body">
                            <div class="form-row">
                                <div class="col-3">
