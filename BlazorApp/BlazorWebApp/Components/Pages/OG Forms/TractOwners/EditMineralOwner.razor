                                        @* <select id="ListAllCounties" class="form-control" style="align-self:center; width:275px;">
                                            <option value="0">Select State</option>
                                            @foreach (var item in ListOfStates)
                                            {
                                                <option value="@item.Id">@item.State</option>
                                            }
                                        </select> *@
                                    }
                                    else
                                    if (InitialState == false)
                                    {
                                        <InputText @bind-Value="@ownership.LeaseId" class="form-control-sm text-sm-right" style="align-self:center; width:200px;" placeholder="(Ex. 1/4 or .25000000)"></InputText>
                                    }
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="col-3">
                                    <label class="opacity-50 form-control-sm mb-0">Total</label>
                                </div>
                                <div class="col" style="padding-bottom:3px;">
                                    @if (InitialState == true)
                                    {
                                        @* <select id="ListAllCounties" class="form-control" style="align-self:center; width:275px;">
                                            <option value="0">Select State</option>
                                            @foreach (var item in ListOfStates)
                                            {
                                                <option value="@item.Id">@item.State</option>
                                            }
                                        </select> *@
                                    }
                                    else
                                    if (InitialState == false)
                                    {
                                        <InputNumber @bind-Value="@ownership.Total" class="form-control-sm text-sm-right" style="align-self:center; width:200px;" placeholder="(Ex. 1/4 or .25000000)"></InputNumber>
                                    }
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="col-3">
