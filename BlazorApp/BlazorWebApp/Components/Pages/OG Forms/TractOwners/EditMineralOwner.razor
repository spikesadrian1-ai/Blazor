                                       @*  <select id="ListAllCounties" class="form-control" style="align-self:center; width:auto;">
                                            <option value="0">Select Region</option>
                                            @foreach (var item in ListAllCounties)
                                            {
                                                <option value="@item.Id">@item.</option>
                                            }
                                        </select> *@
                                    }
                                    else
                                    if (InitialState == false)
                                    {
                                        <InputText @bind-Value="ownership.SuspenseCode" class="form-control-sm text-sm-right" style="align-self:center; width:auto;" placeholder="(Ex. Payout)"></InputText>
                                    }
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="col-3">
                                    <label class="opacity-50 form-control-sm mb-0">Tenure</label>
                                </div>
                                <div class="col" style="padding-bottom:3px;">
                                    @if (InitialState == true)
                                    {
                                        @* <select id="ListAllCounties" class="form-control" style="align-self:center; width:auto;">
                                            <option value="0">Select Region</option>
                                            @foreach (var item in ListAllCounties)
                                            {
                                                <option value="@item.Id">@item.</option>
                                            }
                                        </select> *@
                                    }
                                    else
                                    if (InitialState == false)
                                    {
                                        <InputText @bind-Value="ownership.TenureCode" class="form-control-sm text-sm-right" style="align-self:center; width:auto;" placeholder="(Ex. Payout)"></InputText>
                                    }
                                </div>
                            </div>
                            <br />
                        </div>
                    </div>
                    <div class="col-6" >
                        <div class="card-header form-control">Owner Acreage</div>
                        <div class="card-body">
                            <div class="form-row">
                                <div class="col-3">
                                    <label class="opacity-50 form-control-sm mb-0">Lease</label>
                                </div>
                                <div class="col" style="padding-bottom:3px;">
                                    @if (InitialState == true)
