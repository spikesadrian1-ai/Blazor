                                        <span class="badge badge-primary badge-pill">@item.OwnerId</span>
                                    </div>
                                </div>
                            </div>
                        </li> *@
                        @*              <div class="container-fluid border border-top border-bottom offset-4" style="aspect-ratio:auto">
                            <div class="list-group align-items-baseline  " role="listbox" style="width:auto">
                                <div class="row m-1" style="width:auto; align-content:start" role="listitem">
