@code {

    #region CASCADING PARAMS
    [Parameter] public string? TractID { get; set; } = string.Empty;
    #endregion CASCADING PARAMS

    #region CASCADING PARAMS
    [Parameter] public string? LeaseId { get; set; } = string.Empty;
    #endregion CASCADING PARAMS

    List<TractOwnership> associatedTractOwnersViaTractId { get; set; }
        = new List<TractOwnership>();


    // [Inject]
    // LeaseRelatedPageServices _leaseRelatedPageServices { get; set; }


    string errorString;

    protected override async Task OnInitializedAsync()
    {
        if (TractID != string.Empty)
        {
            var request = new HttpRequestMessage(HttpMethod.Get,
            _config["API_URL"] + $"TractOwnership/SearchAllTractOwnershipByTractId/{TractID}");/*tractOwnership.*/
            var client = _clientFactory.CreateClient();
            HttpResponseMessage response = await client.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                using var responseStream = await response.Content.ReadAsStreamAsync();
                associatedTractOwnersViaTractId = await JsonSerializer
                             .DeserializeAsync<List<TractOwnership>>(responseStream);

                errorString = null;
            }
            else
            {
                errorString = $"There was an error getting Mineral Ownership Data: {response.ReasonPhrase}";
            }
        }

        if (LeaseId != string.Empty)
        {
            associatedTractOwnersViaTractId = await _leaseRelatedPageServices
                .RetreiveAllRelatedMineralOwnersByLeaseIdAsync(LeaseId);
        }

    }


    private AddUpdateMineralOwnerComponent popupRef;

    private void RedirectPage()
    {
        // Shows the popup at the center of the screen
        popupRef.Show("Popup body text");
    }

}