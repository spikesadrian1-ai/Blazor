
@if (Parent.ActivePage == this)
{
    @ChildContent
}




@code
{

    [CascadingParameter]
    private SubTabControl Parent { get; set; }

    [Parameter]
    public RenderFragment ChildContent { get; set; }
    
    [Parameter]
    public string Text { get; set; }

    /// <summary>
    ///
    /// </summary>
    protected override void OnInitialized()
    {
        if (Parent == null)
            throw new ArgumentNullException(nameof(Parent), "SubTabPage must exist within a SubTabControl");
        base.OnInitialized();

        Parent.AddPage(this);
    }

}
